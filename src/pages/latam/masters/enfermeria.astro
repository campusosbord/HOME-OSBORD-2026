---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CourseAccordion from '../../../components/CourseAccordion.astro';
import Testimonials from '../../../components/Testimonials.astro';
import TeachersSection from '../../../components/TeachersSection.astro';
import FAQ from '../../../components/FAQ.astro';
import CTASection from '../../../components/CTASection.astro';
import { Image } from 'astro:assets';
import healthImg from '../../../assets/school_health.png';
import AccreditationBadge from '../../../components/AccreditationBadge.astro';
import LeadForm from '../../../components/LeadForm.astro';
import WhatsAppBox from '../../../components/WhatsAppBox.astro';
import BenefitsSection from '../../../components/BenefitsSection.astro';
import DiplomaSection from '../../../components/DiplomaSection.astro';
import TeachersSection from '../../../components/TeachersSection.astro';

const isUS = false; // Hardcoded for this file
const programName = "Auxiliar de Enfermería Clínica";
const formationFullName = "Curso Profesional Superior: Auxiliar de Enfermería Clínica";

const benefits = [
  {
    title: "Certificación Internacional",
    description: "Consigue tu certificado de finalización. Al culminar tus estudios, se te otorgará en idioma español o inglés con validez institucional.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>',
    tag: "Validez"
  },
  {
    title: "Incremento de Salario",
    description: "La certificación técnica de alto nivel aumenta tus oportunidades de conseguir un mejor empleo y mejora significativamente tu base salarial.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>',
    tag: "Impacto Real"
  },
  {
    title: "Mejor Empleabilidad",
    description: "Los empleadores en el sector salud prefieren contratar personal certificado debido a su nivel de formación, ética y habilidades técnicas demostradas.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0 1 12 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2m4 6h.01M5 20h14a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/></svg>',
    tag: "Alta Demanda"
  },
  {
    title: "Superación Profesional",
    description: "Obtener una certificación reconocida por la industria te brinda una sensación de logro personal y autoridad en tu entorno laboral.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.048 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>',
    tag: "Liderazgo"
  },
  {
    title: "Impacto Social Positivo",
    description: "Tu formación técnica te permite contribuir directamente al bienestar de otros, generando un cambio real en la salud de tu comunidad.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>',
    tag: "Vocación"
  },
  {
    title: "Metodología Flex-Online",
    description: "Estudia a tu propio ritmo con nuestra plataforma de última generación, diseñada para profesionales activos que necesitan flexibilidad total.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18c-2.305 0-4.408.867-6 2.292m0-14.25v14.25"/></svg>',
    tag: "100% Online"
  }
];

const syllabus = [
  { 
    title: "MÓDULO I: FUNDAMENTOS CIENTÍFICOS Y MARCO LEGAL PROFESIONAL", 
    content: [
      "Epistemología de la Enfermería: De Florence Nightingale a la enfermería basada en la evidencia (EBE).",
      "Anatomía Funcional y Fisiopatología Humana: Estudio profundo de la enfermedad como alteración del equilibrio homeostático.",
      "Antropología de los Cuidados: El paciente como ser biopsicosocial y cultural.",
      "Derecho Sanitario y Bioética Médica: Responsabilidad civil, mala praxis, secreto profesional y el consentimiento informado avanzado.",
      "Comunicación Terapéutica: Manejo de malas noticias y psicología del paciente crítico.",
      "Examen de Evaluación: Módulo I."
    ]
  },
  { 
    title: "MÓDULO II: SEGURIDAD DEL PACIENTE, BIOSEGURIDAD Y CONTROL DE INFECCIONES", 
    content: [
      "Microbiología y Parasitología Clínica: Identificación de patógenos hospitalarios.",
      "Gestión de IAAS (Infecciones Asociadas a la Atención de Salud): Vigilancia epidemiológica.",
      "Protocolos de Esterilización de Vanguardia: Autoclave, plasma de peróxido de hidrógeno y gestión de centrales de esterilización.",
      "Toxicología y Manejo de Residuos Biopeligrosos: Normativa internacional.",
      "Examen de Evaluación: Módulo II."
    ]
  },
  { 
    title: "MÓDULO III: VALORACIÓN CLÍNICA Y CONSTANTES VITALES AVANZADAS", 
    content: [
      "Semiología de las Constantes Vitales: Interpretación de arritmias básicas en monitor y oximetría de pulso avanzada.",
      "Exploración Física Sistémica: Técnicas de inspección, palpación, percusión y auscultación para el auxiliar.",
      "Monitorización Invasiva y No Invasiva: Configuración de monitores multiparamétricos de alta complejidad.",
      "Examen de Evaluación: Módulo III."
    ]
  },
  { 
    title: "MÓDULO IV: FARMACOLOGÍA CLÍNICA Y TERAPÉUTICA", 
    content: [
      "Farmacocinética y Farmacodinamia Básica: Cómo actúan los fármacos.",
      "Cálculo de Dosis y Diluciones: Regla de tres, microgoteo y manejo de bombas de infusión continua.",
      "Vías de Administración Complejas: Cuidados en vías centrales, nutrición parenteral y administración de hemoderivados (sangre).",
      "Farmacovigilancia: Identificación precoz de reacciones adversas a medicamentos (RAM).",
      "Técnicas de Inyectología y Vías de Administración Parenteral.",
      "Examen de Evaluación: Módulo IV."
    ]
  },
  { 
    title: "MÓDULO V: CUIDADOS QUIRÚRGICOS Y ASISTENCIA EN QUIRÓFANO", 
    content: [
      "Anestesiología: Tipos de anestesia, fármacos anestésicos y cuidados en la unidad de recuperación post-anestésica (URPA).",
      "Instrumentación Quirúrgica por Especialidades: Cirugía general, traumatología y laparoscopia.",
      "Suturas y Hemostasia: Materiales de sutura avanzados y asistencia en el cierre de heridas complejas.",
      "Manejo de la Unidad Quirúrgica de Alta Complejidad: Flujos de aire, presión positiva y áreas blancas/grises.",
      "Examen de Evaluación: Módulo V."
    ]
  },
  { 
    title: "MÓDULO VI: MEDICINA DE EMERGENCIAS Y SOPORTE VITAL AVANZADO", 
    content: [
      "Soporte Vital Básico y Avanzado (BLS/ACLS): Algoritmos internacionales de la AHA (American Heart Association).",
      "Trauma Shock: Manejo del paciente politraumatizado (ABCDE del trauma).",
      "Triage Hospitalario y Extra-hospitalario: Escalas Manchester y START.",
      "Urgencias Metabólicas y Cardiovasculares: Manejo de infartos (IAM), crisis hipertensivas y shock anafiláctico.",
      "Técnicas de Inmovilización y Vendajes Clínicos.",
      "Examen de Evaluación: Módulo VI."
    ]
  },
  { 
    title: "MÓDULO VII: ENFERMERÍA MATERNO-PERINATAL Y NEONATOLOGÍA", 
    content: [
      "Ginecología y Obstetricia: Control prenatal, fisiología del parto y distocias (complicaciones).",
      "Asistencia en el Parto y Alumbramiento: Rol activo del auxiliar en la sala de partos.",
      "Cuidados Intensivos Neonatales: Manejo de incubadoras, fototerapia y asistencia en el recién nacido prematuro.",
      "Examen de Evaluación: Módulo VII."
    ]
  },
  { 
    title: "MÓDULO VIII: PEDIATRÍA CLÍNICA", 
    content: [
      "Semiología y Valoración Pediátrica: Técnicas de exploración física dirigida al niño. El Triángulo de Evaluación Pediátrica (TEP) para la identificación rápida del estado fisiológico (Apariencia, Respiración y Circulación).",
      "Fisiopatología Infantil: Estudio de las patologías prevalentes: afecciones respiratorias agudas (Bronquiolitis, Laringitis, Neumonía), trastornos digestivos y deshidratación hidroelectrolítica (Manejo de balances hídricos).",
      "Farmacoterapia Pediátrica de Precisión: Farmacología clínica aplicada a la infancia. Cálculo crítico de dosis según peso y superficie corporal. Protocolos de seguridad en la administración de fármacos de alta vigilancia.",
      "Soporte Vital Pediátrico (PALS): Algoritmos de reanimación cardiopulmonar avanzada en pediatría. Manejo de la obstrucción de la vía aérea por cuerpo extraño (OVACE) y tratamiento de crisis convulsivas febriles.",
      "Cuidados Integrales y Confort del Infante: Higiene clínica del lactante y niño pequeño (baño de inmersión y esponja), cuidados de la piel y prevención de dermatitis. Técnicas de confort, manejo del sueño y termorregulación en el paciente hospitalizado.",
      "Nutriología y Dietoterapia Infantil: Lactancia materna y apoyo en la alimentación complementaria. Preparación técnica de fórmulas infantiles y manejo de la nutrición enteral y parenteral pediátrica.",
      "Procedimientos Clínicos e Instrumentación: Técnicas de venopunción pediátrica, sondaje nasogástrico, recogida de muestras estériles y asistencia en procedimientos invasivos (punción lumbar, toracocentesis).",
      "Inmunología Clínica y Vacunología: Bases inmunológicas de la vacunación infantil. Cadena de frío, calendarios de inmunización y manejo de reacciones adversas post-vacunales.",
      "Examen de Evaluación: Módulo VIII."
    ]
  },
  { 
    title: "MÓDULO IX: CUIDADOS EN EL PACIENTE CRÍTICO (UCI) Y GERIATRÍA AVANZADA", 
    content: [
      "Unidad de Cuidados Intensivos: Manejo del paciente ventilado y sedado.",
      "Cuidados Paliativos y Manejo del Dolor: Escalas de dolor y uso de bombas de morfina.",
      "Gerontología Médica: Síndromes geriátricos, demencias y atención al paciente con Alzheimer avanzado.",
      "Examen de Evaluación: Módulo IX."
    ]
  },
  { 
    title: "MÓDULO X: PROCEDIMIENTOS DE DIAGNÓSTICO Y LABORATORIO", 
    content: [
      "Técnicas de Venopunción Avanzada: Uso de catéteres periféricos, mariposas y sistemas de vacío (Vacutainer).",
      "Toma de Muestras Especiales: Hemocultivos, urocultivos, toma de citologías y exudados.",
      "Imagenología para Auxiliares: Preparación del paciente para TAC, Resonancia Magnética (RM) y Medicina Nuclear.",
      "Electrocardiografía Clínica: Toma de EKG de 12 derivaciones e identificación de patrones de urgencia.",
      "Examen de Evaluación: Módulo X."
    ]
  },
  { 
    title: "MÓDULO XI: SALUD MENTAL Y PSIQUIATRÍA CLÍNICA", 
    content: [
      "Psicopatología: Trastornos de la personalidad, psicosis y trastornos afectivos.",
      "Intervención en Crisis y Contención: Técnicas de contención física y farmacológica segura.",
      "Examen de Evaluación: Módulo XI."
    ]
  },
  { 
    title: "MÓDULO XII: TECNOLOGÍA SANITARIA Y SALUD DIGITAL (e-HEALTH)", 
    content: [
      "Gestión de Historias Clínicas Electrónicas: Software hospitalario de alta gama.",
      "Telemedicina y Tele-enfermería: Soporte técnico y humano en consultas remotas.",
      "Big Data en Salud: Introducción a la gestión de datos clínicos.",
      "Examen de Evaluación: Módulo XII."
    ]
  },
  { 
    title: "MÓDULO XIII: INTEGRACIÓN PROFESIONAL Y EVIDENCIA CLÍNICA", 
    content: [
      "Metodología de la Investigación: Cómo realizar un estudio de caso clínico.",
      "Simulación Clínica de Alta Fidelidad: Evaluación práctica ante casos críticos.",
      "Ética, Deontología y Liderazgo en el Equipo de Salud.",
      "Examen de Evaluación: Módulo XIII."
    ]
  },
  { 
    title: "EVALUACIÓN FINAL", 
    content: [
      "Evaluación Final"
    ]
  }
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Curso Profesional Superior: Auxiliar de Enfermería Clínica",
  "description": "Formación técnica de élite en asistencia sanitaria con certificación internacional. 14 módulos especializados con diploma apostillado.",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Instituto Online Osbord",
    "url": "https://osbord.edu"
  },
  "educationalLevel": "Máster",
  "numberOfCredits": 60,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT600H"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://osbord.edu" },
    { "@type": "ListItem", "position": 2, "name": "Escuela de Ciencias de la Salud", "item": "https://osbord.edu/escuela/salud" },
    { "@type": "ListItem", "position": 3, "name": "Curso Profesional Superior: Auxiliar de Enfermería Clínica", "item": "https://osbord.edu/masters/enfermeria" }
  ]
};
---

<Layout
  title="Curso Profesional Superior: Auxiliar de Enfermería Clínica"
  description="Obtén tu certificación internacional en Auxiliar de Enfermería Clínica. Formación técnica de élite con 14 módulos especializados, diploma apostillado y sede en USA."
>
  <!-- Per-page Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header />
  <main>
    <!-- Course Hero -->
    <section class="bg-brand-navy py-24 lg:py-32 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-40">
        <Image src={healthImg} alt="Formación en Enfermería" class="w-full h-full object-cover" width={1920} height={1080} loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/60 to-transparent"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <!-- Breadcrumb -->
        <nav class="mb-12" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/latam/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/latam/escuela/salud" class="hover:text-brand-gold transition-colors">Ciencias de la Salud</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-gold font-semibold text-[10px] tracking-widest">Auxiliar de Enfermería Clínica</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8 animate-fade-in-up">
            <span class="section-label">Escuela de Ciencias de la Salud</span>
            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight uppercase">
              AUXILIAR DE <span class="text-brand-gold">ENFERMERÍA CLÍNICA</span>
            </h1>
            <div class="flex items-center gap-4">
              <div class="w-12 h-1 bg-brand-gold"></div>
              <p class="text-xl text-white font-bold tracking-widest uppercase">
                Curso Profesional Superior
              </p>
            </div>
            <p class="text-lg text-gray-200 max-w-lg leading-relaxed">
              Diferénciate con una formación técnica de alto nivel, avalada por estándares internacionales y diseñada para la empleabilidad inmediata en el sector salud.
            </p>

            <!-- Stats Row -->
            <div class="flex flex-wrap items-center gap-8 pt-4">
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">14</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Módulos</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">6 Meses</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">DURACIÓN</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">Online</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">MODALIDAD</p>
              </div>
            </div>
          </div>

          <!-- Form Side (US) or WhatsApp (Latam) -->
          <div class="relative animate-fade-in-up delay-300">
            <div class="absolute -top-10 -right-6 z-20">
              <AccreditationBadge className="scale-75 md:scale-90" />
            </div>
            {isUS ? (
              <LeadForm programName={formationFullName} />
            ) : (
              <WhatsAppBox programName={programName} />
            )}
          </div>
        </div>
      </div>
    </section>



    <!-- Syllabus Section -->
    <section class="section-padding bg-white">
      <div class="grid lg:grid-cols-3 gap-16">
        <!-- Left Column: Info -->
        <div class="lg:col-span-1 space-y-6">
          <p class="section-label">Plan de Estudios</p>
          <h2 class="text-3xl font-extrabold tracking-tight">Programa Académico</h2>
          <div class="gold-divider"></div>
          <p class="text-gray-500 leading-relaxed">
            Un plan de estudios exhaustivo diseñado para cubrir todas las competencias críticas que demanda el sector salud actualmente.
          </p>

          <!-- Includes Card -->
          <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
            <h4 class="font-extrabold text-sm uppercase tracking-wider">¿Qué incluye?</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Acceso al campus virtual.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Tutoría personalizada.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Certificación internacional.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Comunidad privada de egresados.
              </li>
            </ul>
          </div>
        </div>

        <!-- Right Column: Accordion -->
        <div class="lg:col-span-2">
          <CourseAccordion syllabus={syllabus} />
        </div>
      </div>
    </section>

    <BenefitsSection formationName={programName} benefits={benefits} />
    
    <TeachersSection limitTo={["Dra. Carmen Luzardo"]} />
    <DiplomaSection />
    <Testimonials />
    <FAQ />

    <!-- CTA -->
    <CTASection
      variant="dark"
      headline="Inicia tu camino hacia la excelencia sanitaria"
      subtext="Únete a la próxima cohorte del Curso Profesional Superior en Auxiliar de Enfermería y obtén la autoridad que tu carrera merece."
      buttonText="SOLICITAR ADMISIÓN"
    />
