---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import CourseAccordion from '../../../components/CourseAccordion.astro';
import Testimonials from '../../../components/Testimonials.astro';
import FAQ from '../../../components/FAQ.astro';
import CTASection from '../../../components/CTASection.astro';
import TeachersSection from '../../../components/TeachersSection.astro';
import AccreditationBadge from '../../../components/AccreditationBadge.astro';
import { Image } from 'astro:assets';
import designImg from '../../../assets/school_design.png';
import LeadForm from '../../../components/LeadForm.astro';
import WhatsAppBox from '../../../components/WhatsAppBox.astro';
import BenefitsSection from '../../../components/BenefitsSection.astro';
import DiplomaSection from '../../../components/DiplomaSection.astro';

const isUS = false;
const programName = "Interiorismo y Diseño 3D";
const formationFullName = "Máster en Interiorismo, Diseño y Decoración de Interiores 3D";

const blogPosts = await getCollection('blog', ({ data }) => data.category === 'interiorismo');
const displayPosts = blogPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()).slice(0, 4);

const benefits = [
  {
    title: "Portafolio Elite",
    description: "Desarrolla proyectos fotorrealistas de alta gama para el sector inmobiliario de lujo, creando una carta de presentación imbatible.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>',
    tag: "Visualización 3D"
  },
  {
    title: "Valor Profesional",
    description: "Aumenta tus honorarios y autoridad como diseñador experto en herramientas de vanguardia, posicionándote en el mercado premium.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    tag: "Alta Rentabilidad"
  },
  {
    title: "Demanda Global",
    description: "El mercado internacional de arquitectura y Real Estate busca constantemente visualizadores fotorrealistas para sus preventas.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>',
    tag: "Sin Fronteras"
  },
  {
    title: "Dominio Técnico",
    description: "Certificación oficial en el ecosistema 3D más potente: SketchUp para modelado y V-Ray para renderizado arquitectónico profesional.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>',
    tag: "Tech-Elite"
  },
  {
    title: "Red de Contactos",
    description: "Conéctate con arquitectos, desarrolladores y marcas de mobiliario internacionales a través de nuestra red de egresados y partners.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>',
    tag: "Networking"
  },
  {
    title: "Certificado Internacional",
    description: "Obtén un certificado con validez internacional respaldado por nuestra autoridad institucional en Estados Unidos.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>',
    tag: "Legalización"
  }
];

const syllabus = [
  { 
    title: "MÓDULO 1: FUNDAMENTOS ESTRATÉGICOS DEL DISEÑO", 
    content: [
      "Leyes de la Gestalt aplicadas al Interiorismo Moderno.",
      "El Punto Focal 2.0: Experiencias visuales para RRSS.",
      "Equilibrio Dinámico y Asimetría Controlada en el Espacio.",
      "Ritmo Visual: Repetición, Gradación y Contraste.",
      "Teoría del Color Aplicada: Funcional vs. Emocional.",
      "Neuro-arquitectura: Procesamiento Cerebral del Espacio.",
      "Diseño Biofílico: Integración Científica de la Naturaleza.",
      "Iluminación Técnica: Sistemas Funcionales y Ambientales.",
      "Introducción a la Domótica Lumínica y Ritmos Circadianos.",
      "Examen de Evaluación – Módulo 1."
    ]
  },
  { 
    title: "MÓDULO 2: MATERIALES, SOSTENIBILIDAD Y CONSTRUCCIÓN", 
    content: [
      "Materiales de Huella Cero y Biomateriales.",
      "Textiles Inteligentes: Acústica y Sostenibilidad.",
      "Revestimientos Sinterizados y Maderas Tecnológicas.",
      "Interpretación y Dibujo de Planos de Sección y Detalle.",
      "Carpintería a Medida: Despiece y Herrajes Ocultos.",
      "Instalaciones Invisibles: Electricidad y Climatización Estratégica.",
      "Examen de Evaluación – Módulo 2."
    ]
  },
  { 
    title: "MÓDULO 3: SOFTWARE I - DELINEACIÓN Y METODOLOGÍA BIM", 
    content: [
      "Interfaz y Configuración Pro en AutoCAD.",
      "Dibujo Técnico: Muros, Vanos y Estructuras.",
      "Gestión de Capas (Layers) y Bloques Dinámicos.",
      "Maquetación, Escalas e Impresión Profesional.",
      "Demostración Técnica: AutoCAD (Parte I).",
      "Demostración Técnica: AutoCAD (Parte II).",
      "Demostración Técnica: AutoCAD (Parte III).",
      "Fundamentos de la Metodología BIM en 2026.",
      "Modelado Paramétrico de Interiores con Revit.",
      "Demostración Técnica: Revit (Parte I).",
      "Demostración Técnica: Revit (Parte II).",
      "Demostración Técnica: Revit (Parte III).",
      "Demostración Técnica: Revit (Parte IV).",
      "Demostración Técnica: Revit (Parte V).",
      "Creación de Familias de Mobiliario Personalizado.",
      "Extracción Automática de Presupuestos y Tablas BIM.",
      "Examen de Evaluación – Módulo 3."
    ]
  },
  { 
    title: "MÓDULO 4: SOFTWARE II - MODELADO 3D Y RENDERIZADO", 
    content: [
      "Modelado Ágil y Arquitectónico en SketchUp Pro.",
      "Demostración Técnica: SketchUp (Parte I).",
      "Demostración Técnica: SketchUp (Parte II).",
      "Organización Avanzada: Grupos, Componentes y Etiquetas.",
      "Conectividad y Flujo de Trabajo con Enscape.",
      "Creación de Materiales Realistas (PBR) y Texturizado.",
      "Exportación de Panorámicas 360º y Recorridos Virtuales.",
      "Configuración de Cámaras: Óptica y Composición de Fotograma.",
      "Iluminación de Estudio y Fotorrealismo con V-Ray.",
      "Demostración Técnica: SketchUp + V-Ray Intro.",
      "Demostración Técnica: SketchUp + V-Ray (Parte I).",
      "Demostración Técnica: SketchUp + V-Ray (Parte II).",
      "Examen de Evaluación – Módulo 4."
    ]
  },
  { 
    title: "MÓDULO 5: SOFTWARE III - IA Y POST-PRODUCCIÓN DIGITAL", 
    content: [
      "IA Generativa: Midjourney para Conceptos de Diseño.",
      "Adobe Firefly: Edición y Relleno Generativo de Espacios.",
      "IA para Renders Instantáneos: Metodología Veras AI.",
      "Post-producción Avanzada de Renders en Photoshop.",
      "Fotomontajes e Integración en Entornos Reales.",
      "Examen de Evaluación – Módulo 5."
    ]
  },
  { 
    title: "MÓDULO 6: GESTIÓN DE PROYECTOS Y BUSINESS DESIGN", 
    content: [
      "Ciclo de vida del proyecto - Metodología operativa y gestión de expectativas.",
      "Ingeniería de Costos: Cálculo de Honorarios y Presupuestos.",
      "Mercado Global: Venta de servicios de Renders (USA/España).",
      "Branding y Portafolio de Alto Impacto para Diseñadores.",
      "Estrategia de Captación de Clientes en RRSS (TikTok / IG).",
      "Psicología de Ventas y Presentación Ejecutiva al Cliente.",
      "Examen de Evaluación – Módulo 6."
    ]
  },
  { 
    title: "EVALUACIÓN FINAL", 
    content: [
      "Evaluación Final"
    ]
  }
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "description": "Formación técnica de alto nivel en diseño de interiores, modelado 3D y visualización arquitectónica con certificación internacional. 7 módulos especializados con diploma apostillado.",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Instituto Online Osbord",
    "url": "https://osbord.edu"
  },
  "educationalLevel": "Máster",
  "numberOfCredits": 60,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT600H"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://osbord.edu" },
    { "@type": "ListItem", "position": 2, "name": "Escuela de Arquitectura y Diseño", "item": "https://osbord.edu/escuela/design" },
    { "@type": "ListItem", "position": 3, "name": "Máster en Interiorismo, Diseño y Decoración de Interiores 3D", "item": "https://osbord.edu/masters/interiorismo" }
  ]
};
---

<Layout
  title="Máster en Interiorismo, Diseño y Decoración de Interiores 3D"
  description="Domina el diseño de interiores y la visualización 3D. Formación técnica avanzada para el mercado inmobiliario de lujo. Certificación con diploma apostillado."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header />
  <main>
    <!-- Course Hero -->
    <section class="bg-brand-navy py-24 lg:py-32 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-40">
        <Image src={designImg} alt="Diseño de Interiores 3D" class="w-full h-full object-cover" width={1920} height={1080} loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/60 to-transparent"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="mb-12" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/latam/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/latam/escuela/design" class="hover:text-brand-gold transition-colors">Arquitectura y Diseño</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-gold font-semibold text-[10px] tracking-widest">Interiorismo 3D</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8 animate-fade-in-up">
            <span class="section-label">Escuela de Arquitectura y Diseño</span>
            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight uppercase">
              MÁSTER EN <span class="text-brand-gold">INTERIORISMO 3D</span>
            </h1>
            <div class="flex items-center gap-4">
              <div class="w-12 h-1 bg-brand-gold"></div>
              <p class="text-xl text-white font-bold tracking-widest uppercase">
                Diseño y Decoración 3D
              </p>
            </div>
            <p class="text-lg text-gray-200 max-w-lg leading-relaxed">
              Transforma espacios con maestría técnica. Especialización avanzada en diseño de interiores de lujo y visualización arquitectónica fotorrealista.
            </p>

            <!-- Stats Row -->
            <div class="flex flex-wrap items-center gap-8 pt-4">
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">7</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Módulos</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">3 Meses</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Duración</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">Online</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Modalidad</p>
              </div>
            </div>
          </div>

          <!-- Form Side (US) or WhatsApp (Latam) -->
          <div class="relative animate-fade-in-up delay-300">
            <div class="absolute -top-10 -right-6 z-20">
              <AccreditationBadge className="scale-75 md:scale-90" />
            </div>
            {isUS ? (
              <LeadForm programName={formationFullName} />
            ) : (
              <WhatsAppBox programName={programName} />
            )}
          </div>
        </div>
      </div>
    </section>


    <!-- Syllabus Section -->
    <section class="section-padding bg-white">
      <div class="grid lg:grid-cols-3 gap-16">
        <div class="lg:col-span-1 space-y-6">
          <p class="section-label">Plan de Estudios</p>
          <h2 class="text-3xl font-extrabold tracking-tight">Programa Académico</h2>
          <div class="gold-divider"></div>
          <p class="text-gray-500 leading-relaxed">
            Formación integral que combina creatividad artística con dominio técnico de las herramientas 3D más demandadas del mercado.
          </p>

          <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
            <h4 class="font-extrabold text-sm uppercase tracking-wider">¿Qué incluye?</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Acceso al campus virtual.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Biblioteca de assets.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Certificado al finalizar.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Comunidad privada de alumnos.
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-2">
          <CourseAccordion syllabus={syllabus} />
        </div>
      </div>
    </section>

    <BenefitsSection formationName={programName} benefits={benefits} />

    <TeachersSection limitTo={["Prof. Alejandro Vivas"]} />
    <DiplomaSection />
    <Testimonials />
    <!-- Blog Section -->
    {displayPosts.length > 0 && (
      <section class="section-padding bg-brand-neutral border-t border-gray-100">
        <div class="max-w-7xl mx-auto px-6 space-y-12">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="space-y-4">
              <span class="section-label">Artículos del Blog</span>
              <h2 class="text-3xl font-extrabold tracking-tight">Recursos y Aprendizaje</h2>
              <div class="gold-divider"></div>
            </div>
            <a href="/blog/?categoria=interiorismo" class="text-brand-navy font-bold hover:text-brand-gold transition-colors inline-flex items-center gap-2 group">
              Ver todos los artículos
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {displayPosts.map((post) => (
              <article class="bg-white rounded-brand-lg overflow-hidden border border-gray-100 shadow-soft hover:shadow-elevated transition-all duration-300 flex flex-col group">
                <a href={`/blog/${post.data.category}/${post.id}`} class="block aspect-video overflow-hidden bg-brand-neutral">
                  <Image 
                    src={post.data.image} 
                    alt={post.data.title}
                    width={400}
                    height={225}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </a>
                <div class="p-6 flex-1 flex flex-col justify-between space-y-4">
                  <div class="space-y-2">
                    <h3 class="font-extrabold text-base leading-snug text-brand-navy group-hover:text-brand-gold transition-colors line-clamp-2">
                      <a href={`/blog/${post.data.category}/${post.id}`}>{post.data.title}</a>
                    </h3>
                    <p class="text-gray-500 text-xs line-clamp-3 leading-relaxed">
                      {post.data.excerpt}
                    </p>
                  </div>
                  <div class="pt-3 border-t border-gray-50 flex items-center justify-between text-[10px] text-gray-400">
                    <span>{post.data.readingTime} min lectura</span>
                    <a href={`/blog/${post.data.category}/${post.id}`} class="text-brand-navy font-bold hover:text-brand-gold transition-colors">Leer más</a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTASection
      variant="dark"
      headline="Transforma espacios, transforma tu carrera"
      subtext="Únete a la próxima cohorte del Máster en Interiorismo 3D y conviértete en un diseñador de interiores con certificación internacional."
      buttonText="SOLICITAR ADMISIÓN"
      programName={formationFullName}
    />
  </main>
  <Footer />
</Layout>
