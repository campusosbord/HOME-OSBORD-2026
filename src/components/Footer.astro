---
import Logo from './Logo.astro';

interface Props {
  isUS?: boolean;
}

const { isUS: propIsUS } = Astro.props;
const pathname = Astro.url.pathname;
const isUS = propIsUS ?? pathname.startsWith('/us') ?? Astro.locals.isUS ?? false;
const prefix = pathname.startsWith('/us') ? '/us' : '/latam';
---

<footer class="bg-brand-navy text-white pt-20 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16 mb-16">

      <!-- Logo & Description -->
      <div class="space-y-6 lg:col-span-1">
        <a href={`${prefix}/`} class="flex flex-col group">
          <Logo class="h-30 w-auto" light />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
            Institución con sede en Estados Unidos dedicada a la formación técnica de alto nivel. Brindamos el respaldo de una comunidad profesional permanente y estándares de calidad internacional para todos nuestros graduados.
        </p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          <a href="https://www.linkedin.com/company/osbord" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-brand-gold hover:border-brand-gold transition-all duration-300 group/social" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-gray-400 group-hover/social:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/osbordinstituto" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-brand-gold hover:border-brand-gold transition-all duration-300 group/social" aria-label="Instagram">
            <svg class="w-4 h-4 text-gray-400 group-hover/social:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/osbordinstituto" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-brand-gold hover:border-brand-gold transition-all duration-300 group/social" aria-label="Facebook">
            <svg class="w-4 h-4 text-gray-400 group-hover/social:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Institución Links -->
      <div>
        <h4 class="text-sm font-extrabold mb-6 text-brand-gold uppercase tracking-[0.2em]">Institución</h4>
        <ul class="space-y-4">
          <li><a href={`${prefix}/quienes-somos`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Quiénes somos</a></li>
          <li><a href={`${prefix}/sede-usa`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Sede Estados Unidos</a></li>
          <li><a href={`${prefix}/metodologia`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Metodología</a></li>
          <li><a href={`${prefix}/admisiones`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Admisiones</a></li>
          <li><a href={`${prefix}/verificacion`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Verificación de Títulos</a></li>
          <li><a href={`${prefix}/contacto`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Contacto</a></li>
        </ul>
      </div>

      <!-- Escuelas Links -->
      <div>
        <h4 class="text-sm font-extrabold mb-6 text-brand-gold uppercase tracking-[0.2em]">Escuelas</h4>
        <ul class="space-y-4">
          <li><a href={`${prefix}/masters/enfermeria`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Escuela de Ciencias de la Salud</a></li>
          <li><a href={`${prefix}/masters/interiorismo`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Escuela de Arquitectura y Diseño</a></li>
          <li><a href={`${prefix}/masters/wedding-planner`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Escuela de Gestión de Eventos</a></li>
        </ul>

        <h4 class="text-sm font-extrabold mb-4 mt-8 text-brand-gold uppercase tracking-[0.2em]">Programas</h4>
        <ul class="space-y-4">
          <li><a href={`${prefix}/masters/enfermeria`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Curso Profesional Superior: Auxiliar de Enfermería Clínica</a></li>
          <li><a href={`${prefix}/masters/interiorismo`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Máster en Interiorismo, Diseño y Decoración de Interiores 3D</a></li>
          <li><a href={`${prefix}/masters/wedding-planner`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Máster en Organización de Eventos & Wedding Planner + IA</a></li>
        </ul>
      </div>

      <!-- Sede Corporativa -->
      <div>
        <h4 class="text-sm font-extrabold mb-6 text-brand-gold uppercase tracking-[0.2em]">Sede Corporativa</h4>
        <ul class="space-y-5">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            <div class="space-y-1">
              <p class="text-xs text-brand-gold font-bold uppercase tracking-wider">Sede Estados Unidos</p>
              <p class="text-sm text-gray-400 leading-relaxed">30 N Gould St Ste N, Sheridan, WY 82801.</p>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            <a href="mailto:admisiones@osbord.com" class="text-sm text-gray-400 hover:text-white transition-colors">admisiones@osbord.com</a>
          </li>
          {!isUS && (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand-gold flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
              </svg>
              <a href="https://wa.me/13072923715?text=Hola%2C%20vengo%20de%20la%20p%C3%A1gina%20del%20Instituto%20Osbord%20y%20estoy%20interesado%20en%20informaci%C3%B3n%20sobre%20un%20m%C3%A1ster%20o%20curso." target="_blank" rel="noopener noreferrer" class="text-sm text-white font-bold hover:text-brand-gold transition-colors flex items-center gap-2">
                WhatsApp Directo
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                </span>
              </a>
            </li>
          )}
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-[10px] text-gray-500 uppercase tracking-[0.15em] font-bold">
          © {new Date().getFullYear()} Instituto Osbord LLC. Todos los derechos reservados.
        </p>
        <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6">
          <a href={`${prefix}/legal`} class="text-[10px] text-gray-500 uppercase tracking-[0.15em] font-bold hover:text-white transition-colors">Aviso Legal</a>
          <a href={`${prefix}/privacidad`} class="text-[10px] text-gray-500 uppercase tracking-[0.15em] font-bold hover:text-white transition-colors">Privacidad</a>
          <a href={`${prefix}/cookies`} class="text-[10px] text-gray-500 uppercase tracking-[0.15em] font-bold hover:text-white transition-colors">Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>
