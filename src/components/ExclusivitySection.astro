---
---

<section class="bg-white py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
    <!-- Left: Quote & Text -->
    <div class="space-y-8">
      <p class="section-label">Comunidad de Élite</p>
      <h2 class="text-4xl md:text-5xl font-extrabold leading-tight tracking-tight">
        Comunidad Privada &
        <br />
        <span class="text-brand-gold">Mentoría Directa</span>
      </h2>

      <!-- Quote -->
      <blockquote class="relative">
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-brand-gold to-brand-gold/20 rounded-full"></div>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed italic pl-8">
          "No solo entregamos títulos, construimos carreras de alto nivel. Cada alumno tiene acceso a mi red de contactos y mentoría personalizada para asegurar su éxito en el mercado real."
        </p>
      </blockquote>

      <div class="space-y-1 pl-8">
        <p class="font-extrabold text-brand-navy text-lg">Raúl Ramírez</p>
        <p class="text-xs text-gray-400 uppercase tracking-[0.2em] font-bold">Director Académico & Estratega de Negocios</p>
      </div>

      <div class="pt-2 pl-8">
        <a href="/comunidad" class="inline-flex items-center text-brand-gold font-bold text-sm hover:underline underline-offset-4 group/link">
          Conocer el ecosistema Osbord
          <svg class="ml-2 w-5 h-5 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Right: Feature Card -->
    <div class="relative">
      <!-- Decorative blur -->
      <div class="absolute -top-12 -left-12 w-48 h-48 bg-brand-gold/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-8 -right-8 w-36 h-36 bg-brand-navy/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative bg-brand-navy rounded-brand-xl p-10 md:p-12 text-white space-y-8 shadow-2xl">
        <!-- Header -->
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-brand-gold rounded-brand-lg flex items-center justify-center">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-xl font-extrabold">Acceso Exclusivo</h4>
            <p class="text-xs text-gray-400 uppercase tracking-widest font-bold">Solo para alumnos Osbord</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="w-full h-px bg-white/10"></div>

        <!-- Features -->
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
            </span>
            <div>
              <p class="font-bold text-white">Networking Global</p>
              <p class="text-sm text-gray-400 mt-1">Conexión con empresarios y profesionales de alto nivel en más de 10 países.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
            </span>
            <div>
              <p class="font-bold text-white">Sesiones Q&A en Vivo</p>
              <p class="text-sm text-gray-400 mt-1">Sesiones mensuales de preguntas y respuestas con especialistas de la industria.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
            </span>
            <div>
              <p class="font-bold text-white">Bolsa de Empleo Exclusiva</p>
              <p class="text-sm text-gray-400 mt-1">Ofertas laborales curadas para egresados del Instituto Osbord a nivel internacional.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
