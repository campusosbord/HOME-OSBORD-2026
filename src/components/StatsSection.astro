---
const stats = [
  { value: "500+", label: "Egresados en el Mundo" },
  { value: "3", label: "Escuelas de Especialización" },
  { value: "10+", label: "Países Representados" },
  { value: "98%", label: "Tasa de Satisfacción" },
];
---

<section class="bg-brand-navy py-20 relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/4 w-64 h-64 bg-brand-gold/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-brand-gold/3 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {stats.map((stat, index) => (
        <div class={`text-center space-y-3 animate-fade-in-up delay-${(index + 1) * 100}`}>
          <p class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-gold tracking-tight" style={`font-family: var(--font-montserrat);`}>
            {stat.value}
          </p>
          <p class="text-sm text-gray-400 font-medium uppercase tracking-widest">
            {stat.label}
          </p>
          <div class="w-8 h-0.5 bg-brand-gold/30 mx-auto rounded-full"></div>
        </div>
      ))}
    </div>
  </div>
</section>
