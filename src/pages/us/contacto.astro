---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const city = Astro.locals.city || "USA (Ciudad no detectada)";
const origin = Astro.url.href;
---

<Layout title="Contacto" description="Contacta con el Instituto Online Osbord. Estamos aquí para resolver tus dudas sobre admisiones, programas académicos y certificaciones internacionales.">
  <Header />
  <main>
    <section class="bg-brand-navy py-20 lg:py-24 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-navy to-brand-navy-light"></div>
      <div class="relative max-w-7xl mx-auto px-6 text-center space-y-6">
        <span class="section-label">Atención Directa</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight">
          Resolvemos tus<span class="text-brand-gold"> dudas</span>
        </h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
          ¿Tienes preguntas sobre nuestras formaciones o la certificación? Nuestro equipo de admisiones está disponible para asesorarte de forma personalizada.
        </p>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16">
          <!-- Info -->
          <div class="space-y-12">
            <div class="space-y-4">
              <span class="section-label">Canales Oficiales</span>
              <h2 class="text-3xl font-extrabold tracking-tight text-brand-navy">Vías de comunicación</h2>
              <div class="gold-divider"></div>
            </div>

            <div class="grid sm:grid-cols-2 gap-8">
              <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
                <div class="w-10 h-10 bg-brand-gold/10 rounded-brand flex items-center justify-center text-brand-gold">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
                </div>
                <h3 class="font-extrabold text-brand-navy">Correo Electrónico</h3>
                <p class="text-sm text-gray-500">Para consultas académicas generales.</p>
                <a href="mailto:admisiones@osbord.com" class="text-brand-gold font-bold hover:underline">admisiones@osbord.com</a>
              </div>
            </div>

            <div class="p-8 bg-brand-navy text-white rounded-brand-xl space-y-4">
              <h3 class="text-xl font-extrabold text-brand-gold">Presencia Internacional</h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                Nuestras oficinas administrativas centrales se encuentran en Estados Unidos, garantizando la validez internacional de nuestros títulos.
              </p>
              <div class="space-y-4 pt-2">
                <div>
                  <p class="text-[10px] text-brand-gold uppercase tracking-widest font-bold mb-1">Sede Estados Unidos</p>
                  <p class="font-semibold text-white text-sm">30 N Gould St Ste N, Sheridan, WY 82801.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Form -->
          <div class="bg-brand-neutral rounded-brand-xl p-8 md:p-12 border border-gray-100 shadow-soft space-y-8 relative">
            <h3 class="text-2xl font-extrabold text-brand-navy text-center">Envíanos un mensaje</h3>
            <form id="contact-form" class="space-y-6">
              <input type="hidden" name="ciudad" value={city} />
              <input type="hidden" name="origen" value={origin} />
              <div class="grid sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Nombre Completo</label>
                  <input type="text" name="nombre" placeholder="Escribe tu nombre" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold transition-all" required />
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Correo Electrónico</label>
                  <input type="email" name="correo" placeholder="email@ejemplo.com" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold transition-all" required />
                </div>
              </div>
              <div class="grid sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Teléfono</label>
                  <input type="tel" name="telefono" placeholder="+1..." class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold transition-all" required />
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Programa de Interés</label>
                  <select name="formacion" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold transition-all bg-white" required>
                    <option value="">Selecciona un programa</option>
                    <option>Máster en Interiorismo, Diseño y Decoración de Interiores 3D</option>
                    <option>Máster en Organización de Eventos & Wedding Planner + IA</option>
                    <option>Curso Profesional Superior: Auxiliar de Enfermería Clínica</option>
                    <option>Otro / Consulta general</option>
                  </select>
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Mensaje</label>
                <textarea name="mensaje" rows="4" placeholder="¿Cómo podemos ayudarte?" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold transition-all" required></textarea>
              </div>
              <div class="pt-2 flex flex-col items-center gap-3">
                <button type="submit" class="cta-button w-full justify-center text-base py-4">ENVIAR CONSULTA</button>
                
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
                  <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Respuesta en menos de 24 horas</p>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  
  // Client-side City Fallback (Plan B)
  async function resolveCity() {
    const cityInput = contactForm.querySelector('input[name="ciudad"]') as HTMLInputElement;
    if (cityInput && (cityInput.value.includes('no detectada') || cityInput.value.length <= 3 || !cityInput.value)) {
      try {
        const res = await fetch('https://ipapi.co/json/');
        const geo = await res.json();
        if (geo.city) {
          cityInput.value = `${geo.city}, ${geo.region} (${geo.country_name})`;
        }
      } catch (e) {
        console.warn('Geo fallback failed');
      }
    }
  }

  if (contactForm) resolveCity();

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';

    // 1. ID único para deduplicación Meta (Pixel + Conversiones API)
    const eventId = 'lead_' + Date.now() + '_' + Math.random().toString(36).slice(2, 9);
    if ((window as any).fbq) (window as any).fbq('track', 'Lead', {}, { eventID: eventId });
    if ((window as any).gtag) (window as any).gtag('event', 'generate_lead');
    
    const formData = new FormData(contactForm);
    const data: Record<string, string> = Object.fromEntries(formData.entries()) as Record<string, string>;

    // 2. Inyectar variables de seguimiento
    data.event_id = eventId;
    data.user_agent = navigator.userAgent;
    data.page_url = window.location.href;

    // 3. URLSearchParams para evitar bloqueo CORS
    const params = new URLSearchParams();
    for (const [key, value] of Object.entries(data)) {
      params.append(key, value);
    }
    
    try {
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzyWUx6b8Ys6Z6krDXOERDH7Z59iYf7--6hb6H9UHvyoSNM4mEs_ESnx1_LEwcGUuE/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        body: params
      });
      
      window.osbordToast?.();
      contactForm.reset();
    } catch (error) {
      console.error('Error:', error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
