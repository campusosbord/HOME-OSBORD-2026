---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CourseAccordion from '../../components/CourseAccordion.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import { Image } from 'astro:assets';
import designImg from '../../assets/school_design.png';

const syllabus = [
  { 
    title: "Módulo 1: Fundamentos del Diseño de Interiores", 
    content: [
      "Historia del Interiorismo Contemporáneo",
      "Teoría de la Composición y el Espacio",
      "Estilos Decorativos de Vanguardia",
      "Psicología del Color y Percepción",
      "Antropometría y Ergonomía",
      "Briefing y Análisis de Necesidades",
      "Moodboards y Concepto Creativo",
      "Examen de Evaluación: Módulo 1."
    ]
  },
  { 
    title: "Módulo 2: Dibujo Técnico y Planimetría", 
    content: [
      "Representación Gráfica Arquitectónica",
      "Dibujo en Planta, Alzados y Secciones",
      "Simbología y Normas Técnicas",
      "Introducción al CAD 2D",
      "Escalas e Impresión Técnica",
      "Detalles Constructivos Básicos",
      "Examen de Evaluación: Módulo 2."
    ]
  },
  { 
    title: "Módulo 3: Modelado 3D con SketchUp", 
    content: [
      "Interfaz y Herramientas de Modelado",
      "Modelado de Mobiliario a Medida",
      "Gestión de Capas y Grupos",
      "Importación de Planos 2D",
      "Uso de la 3D Warehouse",
      "Creación de Escenas y Recorridos",
      "Modelado de Espacios Complejos",
      "Examen de Evaluación: Módulo 3."
    ]
  },
  { 
    title: "Módulo 4: Renderizado con V-Ray y Blender", 
    content: [
      "Principios de Iluminación Global",
      "Creación y Edición de Materiales PBR",
      "Mapeado de Texturas y UV Mapping",
      "Configuración de Cámaras y Lentes",
      "Renderizado en Tiempo Real vs. Estático",
      "Post-producción en Photoshop",
      "Optimización de Tiempos de Render",
      "Examen de Evaluación: Módulo 4."
    ]
  },
  { 
    title: "Módulo 5: Materiales y Acabados de Lujo", 
    content: [
      "Piedras Naturales y Revestimientos",
      "Maderas y Carpintería de Autor",
      "Textiles y Tapicería Premium",
      "Metales y Vidrios Arquitectónicos",
      "Nuevos Materiales Sostenibles",
      "Presupuestación de Materiales",
      "Examen de Evaluación: Módulo 5."
    ]
  },
  { 
    title: "Módulo 6: Iluminación Arquitectónica", 
    content: [
      "Cálculo Lumínico y Normativa",
      "Tipos de Lámparas y Luminarias",
      "Control de Iluminación y Domótica",
      "Efectos de Luz y Escenarios",
      "Fichas Técnicas de Iluminación",
      "Eficiencia Energética en el Diseño",
      "Examen de Evaluación: Módulo 6."
    ]
  },
  { 
    title: "Módulo 7: Espacios Comerciales y Retail", 
    content: [
      "Marketing Sensorial en el Punto de Venta",
      "Diseño de Escaparates de Lujo",
      "Customer Journey y Flujos",
      "Visual Merchandising Avanzado",
      "Normativas de Locales de Pública Concurrencia",
      "Imagen de Marca Aplicada al Espacio",
      "Examen de Evaluación: Módulo 7."
    ]
  },
  { 
    title: "Módulo 8: Diseño Residencial Premium", 
    content: [
      "Distribución de Viviendas de Alto Standing",
      "Diseño de Cocinas y Baños Gourmet",
      "Home Staging y Estilismo Final",
      "Mobiliario de Diseño Internacional",
      "Instalaciones en el Hogar Inteligente",
      "Paisajismo en Terrazas y Aticos",
      "Examen de Evaluación: Módulo 8."
    ]
  },
  { 
    title: "Módulo 9: Gestión de Proyectos y Obra", 
    content: [
      "Fases del Proyecto de Interiorismo",
      "Gestión de Gremios y Proveedores",
      "Cronogramas de Obra (Diagrama de Gantt)",
      "Presupuestos y Control de Costes",
      "Contratos y Seguros de Obra",
      "Atención al Cliente y Post-Venta",
      "Examen de Evaluación: Módulo 9."
    ]
  },
  { 
    title: "Módulo 10: Proyecto Final de Maestría", 
    content: [
      "Definición del Concepto y Programa",
      "Desarrollo de Planimetría Completa",
      "Modelado y Renders de Alta Calidad",
      "Memoria de Calidades y Presupuesto",
      "Dossier Final de Presentación",
      "Defensa ante el Jurado Académico",
      "Evaluación Final de Grado."
    ]
  }
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "description": "Formación técnica de alto nivel en diseño de interiores, modelado 3D y visualización arquitectónica con certificación internacional. Renderizado fotorrealista y gestión de proyectos de alta gama.",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Instituto Online Osbord",
    "url": "https://osbord.edu"
  },
  "educationalLevel": "Máster",
  "numberOfCredits": 60,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT600H"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://osbord.edu" },
    { "@type": "ListItem", "position": 2, "name": "Escuela de Arquitectura y Diseño", "item": "https://osbord.edu/escuela/design" },
    { "@type": "ListItem", "position": 3, "name": "Máster en Interiorismo, Diseño y Decoración de Interiores 3D", "item": "https://osbord.edu/masters/interiorismo" }
  ]
};
---

<Layout
  title="Máster en Interiorismo, Diseño y Decoración de Interiores 3D"
  description="Domina el diseño de interiores y la visualización 3D. Formación técnica avanzada para el mercado inmobiliario de lujo. Certificación con diploma apostillado."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header />
  <main>
    <!-- Course Hero -->
    <section class="bg-brand-navy py-24 lg:py-28 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-15">
        <Image src={designImg} alt="Diseño de Interiores 3D" class="w-full h-full object-cover" width={1920} height={1080} loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/90 to-brand-navy/60"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/escuela/design" class="hover:text-brand-gold transition-colors">Arquitectura y Diseño</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-gold font-semibold uppercase text-[10px] tracking-widest">Máster en Interiorismo, Diseño y Decoración de Interiores 3D</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6 animate-fade-in-up">
            <span class="section-label">Escuela de Arquitectura y Diseño</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] tracking-tight">
              Máster en Interiorismo, Diseño <span class="text-brand-gold">y Decoración 3D</span>
            </h1>
            <p class="text-lg text-gray-300 max-w-lg leading-relaxed">
              Transforma espacios con maestría técnica. Especialización en diseño de interiores de lujo y visualización arquitectónica fotorrealista.
            </p>

            <div class="flex items-center gap-8 pt-4 animate-fade-in-up delay-200">
              <div class="text-center">
                <p class="text-brand-gold font-extrabold text-2xl lg:text-3xl">10</p>
                <p class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-bold mt-1">Módulos</p>
              </div>
              <div class="w-px h-10 bg-white/10"></div>
              <div class="text-center">
                <p class="text-brand-gold font-extrabold text-2xl lg:text-3xl">USA</p>
                <p class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-bold mt-1">Certificación</p>
              </div>
              <div class="w-px h-10 bg-white/10"></div>
              <div class="text-center">
                <p class="text-brand-gold font-extrabold text-2xl lg:text-3xl">Online</p>
                <p class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-bold mt-1">Metodología</p>
              </div>
              <div class="w-px h-10 bg-white/10"></div>
              <div class="text-center">
                <p class="text-brand-gold font-extrabold text-2xl lg:text-3xl">600h</p>
                <p class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-bold mt-1">Duración</p>
              </div>
            </div>

            <div class="pt-4 animate-fade-in-up delay-300">
              <a href="https://wa.me/1234567890" class="cta-button text-base px-10 py-4">
                DESCARGAR BROCHURE & ADMISIÓN
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Syllabus Section -->
    <section class="section-padding bg-white">
      <div class="grid lg:grid-cols-3 gap-16">
        <div class="lg:col-span-1 space-y-6">
          <p class="section-label">Plan de Estudios</p>
          <h2 class="text-3xl font-extrabold tracking-tight">Programa Académico</h2>
          <div class="gold-divider"></div>
          <p class="text-gray-500 leading-relaxed">
            Formación integral que combina creatividad artística con dominio técnico de las herramientas 3D más demandadas del mercado.
          </p>

          <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
            <h4 class="font-extrabold text-sm uppercase tracking-wider">¿Qué incluye?</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Licencias de software incluidas.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Biblioteca de assets y texturas premium.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Diploma apostillado por la Haya.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Portfolio profesional al finalizar.
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-2">
          <CourseAccordion syllabus={syllabus} />
        </div>
      </div>
    </section>

    <Testimonials />
    <FAQ />

    <CTASection
      variant="dark"
      headline="Transforma espacios, transforma tu carrera"
      subtext="Únete a la próxima cohorte del Máster en Interiorismo 3D y conviértete en un diseñador de interiores con certificación internacional."
      buttonText="HABLAR CON UN ASESOR"
    />
  </main>
  <Footer />
</Layout>
