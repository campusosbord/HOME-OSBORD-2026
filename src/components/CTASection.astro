---
interface Props {
  headline?: string;
  subtext?: string;
  buttonText?: string;
  buttonLink?: string;
  programName?: string;
  variant?: 'light' | 'dark';
}

const {
  headline = "¿Listo para elevar tu perfil profesional?",
  subtext = "El proceso de admisión está abierto para las próximas cohortes. Asegura tu lugar en una institución que valora la calidad sobre la cantidad.",
  buttonText = "SOLICITAR ADMISIÓN",
  buttonLink,
  programName,
  variant = 'light',
} = Astro.props;

const isDark = variant === 'dark';
const pathname = Astro.url.pathname;
const isLatam = pathname.startsWith('/latam') || pathname.includes('/latam/');

let finalLink = buttonLink;
if (!finalLink) {
  if (programName) {
    const encodedText = encodeURIComponent(`Hola, vengo de la página del Instituto Osbord y estoy interesado en información sobre el ${programName}.`);
    finalLink = `https://wa.me/13072923715?text=${encodedText}`;
  } else {
    finalLink = "https://wa.me/13072923715?text=Hola%2C%20vengo%20de%20la%20p%C3%A1gina%20del%20Instituto%20Osbord%20y%20estoy%20interesado%20en%20informaci%C3%B3n%20sobre%20un%20m%C3%A1ster%20o%20curso.";
  }
}
---

<section class={`py-12 relative overflow-hidden ${isDark ? 'bg-brand-navy' : 'bg-brand-neutral'}`}>
  <!-- Decorative -->
  {isDark && (
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-gold/3 rounded-full blur-3xl"></div>
    </div>
  )}

  <div class="relative max-w-3xl mx-auto px-6 text-center space-y-6">
    <h2 class={`text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight ${isDark ? 'text-white' : ''}`}>
      {headline}
    </h2>
    <p class={`text-lg max-w-2xl mx-auto leading-relaxed ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
      {subtext}
    </p>
    <div id="seccion-contacto" class="flex justify-center pt-2">
      {isLatam ? (
        <a href={finalLink} target="_blank" rel="noopener noreferrer" class="group/cta cta-button cta-dynamic text-xs md:text-sm px-8 md:px-10 py-3 md:py-3.5 flex items-center justify-center gap-3 transition-all duration-300 hover:bg-white hover:text-brand-navy">
          <svg class="w-6 h-6 transition-all duration-300 fill-white group-hover/cta:fill-brand-navy" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
          </svg>
          {buttonText}
        </a>
      ) : (
        <button class="trigger-admission-modal group/cta cta-button cta-dynamic text-xs md:text-sm px-8 md:px-10 py-3 md:py-3.5 flex items-center justify-center gap-3 transition-all duration-300 hover:bg-white hover:text-brand-navy">
          <svg class="w-6 h-6 transition-all duration-300 fill-white group-hover/cta:fill-brand-navy" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {buttonText}
        </button>
      )}
    </div>

    <div class="space-y-4">
      {isLatam ? (
        <div class="flex items-center justify-center gap-2.5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <p class={`text-[10px] uppercase tracking-[0.2em] font-bold ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
            Respuesta inmediata por WhatsApp
          </p>
        </div>
      ) : (
        <div class="flex items-center justify-center gap-2 pt-2">
          <div class="w-2 h-2 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
          <p class={`text-[10px] text-gray-400 uppercase tracking-widest font-bold ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
            Respuesta en menos de 24 horas
          </p>
        </div>
      )}
    </div>
  </div>
</section>

<!-- Decorative Elements -->
<div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>
