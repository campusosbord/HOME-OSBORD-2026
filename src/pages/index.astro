---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Redirigiendo..." description="Detectando tu ubicación para ofrecerte la mejor experiencia.">
  <div class="min-h-screen bg-brand-navy flex flex-col items-center justify-center text-center px-6">
    <div class="w-16 h-16 border-4 border-brand-gold/20 border-t-brand-gold rounded-full animate-spin mb-8"></div>
    <h1 class="text-white text-2xl font-extrabold tracking-tight mb-2">Cargando experiencia...</h1>
    <p class="text-gray-400 text-sm">Detectando tu ubicación para ofrecerte la mejor atención personalizada.</p>
  </div>
</Layout>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>
