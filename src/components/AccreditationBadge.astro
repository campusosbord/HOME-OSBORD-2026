---
interface Props {
  variant?: 'gold' | 'white';
  className?: string;
}

const { variant = 'gold', className = "" } = Astro.props;
---

<div class={`relative w-20 h-20 md:w-24 md:h-24 flex items-center justify-center ${className}`}>
  <!-- Outer Shadow for Depth -->
  <div class="absolute inset-0 rounded-full shadow-[0_8px_30px_rgba(0,0,0,0.12)]"></div>
  
  <!-- The Gold Circle (Real Gold Effect) -->
  <div class={`relative w-full h-full rounded-full flex flex-col items-center justify-center text-center p-3 border border-[#B8860B]/30 overflow-hidden ${variant === 'gold' ? 'bg-gradient-to-br from-[#BF953F] via-[#FCF6BA] to-[#AA771C]' : 'bg-white'}`}>
    
    <!-- Metallic Highlights -->
    <div class="absolute inset-0 opacity-40 bg-gradient-to-tr from-transparent via-white/40 to-transparent skew-x-12"></div>
    
    <!-- Inner Fine Ring -->
    <div class="absolute inset-1.5 rounded-full border-[0.5px] border-black/10"></div>

    <div class="relative z-10 flex flex-col items-center w-full px-1">
      <!-- Institutional Icon: Simplified Victory Mark -->
      <svg class="w-4 h-4 md:w-5 md:h-5 mb-1 text-black/80" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2L15.09 8.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      
      <!-- Typography Highly Compressed to Fit Small Seal -->
      <p class="text-[6.5px] md:text-[8px] font-black text-black uppercase tracking-tight leading-[1.1] w-full">
        Validez<br/>Internacional
      </p>
    </div>
  </div>
</div>
