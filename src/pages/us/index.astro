---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import SchoolSection from '../../components/SchoolSection.astro';
import StatsSection from '../../components/StatsSection.astro';
import ExclusivitySection from '../../components/ExclusivitySection.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import TeachersSection from '../../components/TeachersSection.astro';
import AccreditationBadge from '../../components/AccreditationBadge.astro';

const city = Astro.request.headers.get('x-nf-city') || "Unknown City";
---

<Layout
  title="Osbord USA — Admisión Institucional"
  description="Instituto Online Osbord USA. Másters de alto nivel con certificación internacional y enfoque institucional."
>
  <Header isUS={true} />
  <main>
    <Hero isUS={true} />
    <TrustBar />
    <SchoolSection />
    <StatsSection />
    <ExclusivitySection />
    <TeachersSection />
    
    <!-- Seccion de Formulario para USA -->
    <section id="contacto-usa" class="py-24 bg-brand-neutral">
      <div class="max-w-4xl mx-auto px-6 relative">
        <AccreditationBadge className="absolute -top-12 right-0 z-10" />
        <div class="bg-white p-12 rounded-brand-xl shadow-elevated border border-gray-100">
          <div class="text-center mb-10 space-y-4">
            <span class="section-label">Admisión Institucional</span>
            <h2 class="text-3xl font-extrabold tracking-tight">Solicitud de Información</h2>
            <p class="text-gray-500">Complete el siguiente formulario para recibir nuestro brochure institucional y los requisitos de admisión.</p>
          </div>
          <form class="space-y-6" id="index-contact-form">
            <input type="hidden" name="city" value={city} />
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Nombre Completo</label>
                <input type="text" placeholder="Escribe tu nombre" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all" required />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Correo Electrónico</label>
                <input type="email" placeholder="email@ejemplo.com" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all" required />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Teléfono</label>
                <input type="tel" placeholder="+1..." class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all" required />
                
                <div class="space-y-2 mt-4">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
                  <div class="flex items-center gap-6">
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="index-whatsapp" value="si" class="w-4 h-4 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-xs font-bold text-brand-navy uppercase tracking-wider group-hover:text-brand-gold transition-colors">Sí</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="index-whatsapp" value="no" class="w-4 h-4 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-xs font-bold text-brand-navy uppercase tracking-wider group-hover:text-brand-gold transition-colors">No</span>
                    </label>
                  </div>
                </div>
              </div>
              
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Programa de Interés</label>
                <select class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all bg-white" required>
                  <option value="" disabled selected>Selecciona un programa</option>
                  <option>Máster en Interiorismo, Diseño y Decoración de Interiores 3D</option>
                  <option>Máster en Organización de Eventos & Wedding Planner + IA</option>
                  <option>CURSO PROFESIONAL SUPERIOR: AUXILIAR DE ENFERMERÍA CLÍNICA</option>
                </select>
              </div>
            </div>

            <div class="pt-6">
              <button type="submit" class="cta-button w-full justify-center py-5 text-lg">ENVIAR SOLICITUD DE ADMISIÓN</button>
              <p class="text-[10px] text-center text-gray-400 mt-4 uppercase tracking-[0.2em] font-medium">Procesamiento de solicitud prioritario</p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <Testimonials />
    <FAQ />
  </main>
  <Footer isUS={true} />
</Layout>

<script>
  const indexForm = document.getElementById('index-contact-form') as HTMLFormElement;
  
  indexForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = indexForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    
    const formData = new FormData(indexForm);
    const data = Object.fromEntries(formData.entries());
    
    try {
      // Reemplaza con la URL real de tu Google Apps Script
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbz_XXXXXXXXX/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      alert('¡Gracias! Tu solicitud de admisión ha sido enviada correctamente.');
      indexForm.reset();
    } catch (error) {
      console.error('Error:', error);
      alert('Hubo un error al enviar el formulario. Por favor, intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
