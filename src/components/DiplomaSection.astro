---
import { Image } from 'astro:assets';
import diplomaImg from '../assets/diploma-v2.png';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<section class={`py-16 bg-brand-navy relative overflow-hidden ${className}`}>
  <!-- Grid Background -->
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 1.5px 1.5px, rgba(255,255,255,0.1) 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      
      <!-- Diploma Image with Hover Effect -->
      <div class="lg:w-1/2 relative group perspective-1000">
        <!-- Main Tilting Wrapper -->
        <div class="relative transition-all duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)] transform group-hover:rotate-0 -rotate-3 group-hover:scale-[1.02]">
          
          <!-- Diploma Inner Container (with overflow for gloss) -->
          <div class="relative shadow-[0_50px_100px_-20px_rgba(0,0,0,0.5)] rounded-sm overflow-hidden border-[6px] border-white">
            <Image 
              src={diplomaImg} 
              alt="Certificación Instituto Osbord" 
              class="w-full h-auto block"
            />
            
            <!-- Gloss Effect -->
            <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/5 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 pointer-events-none"></div>
          </div>

          <!-- Validez Global Badge - Now follows parent tilt -->
          <div class="absolute -bottom-6 -right-6 lg:-bottom-10 lg:-right-10 w-24 h-24 md:w-28 md:h-28 bg-brand-gold rounded-full flex items-center justify-center text-center p-3 border-[6px] border-white shadow-2xl z-20 transition-all duration-700 pointer-events-none group-hover:scale-110">
            <span class="text-[10px] md:text-xs font-black text-brand-navy leading-tight uppercase tracking-tight">Validez<br/>Global</span>
          </div>
        </div>
        
        <!-- Decorative Glow -->
        <div class="absolute -inset-10 bg-brand-gold/5 blur-[100px] rounded-full -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
      </div>

      <!-- Content -->
      <div class="lg:w-1/2 space-y-10">
        <div class="space-y-6">
          <h2 class="text-4xl md:text-5xl font-extrabold text-white leading-[1.1] tracking-tight">
            Estudia con el respaldo del <br/>
            <span class="text-brand-gold">Instituto Osbord</span>
          </h2>
          
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed max-w-xl font-medium">
            Nuestra Sede Matriz en <span class="text-white">Estados Unidos</span> garantiza que tu formación cumple con los más altos estándares internacionales. Al graduarte, no solo recibes un título, recibes una llave al mercado laboral global.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-brand bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-gold/20 group-hover:border-brand-gold/30 transition-all duration-300">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-white font-bold text-sm tracking-wide">Certificación avalada en EE.UU.</span>
          </div>
          
          <div class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-brand bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-gold/20 group-hover:border-brand-gold/30 transition-all duration-300">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-white font-bold text-sm tracking-wide">Acceso al campus virtual</span>
          </div>
          
          <div class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-brand bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-gold/20 group-hover:border-brand-gold/30 transition-all duration-300">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-white font-bold text-sm tracking-wide">Networking internacional</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Strategic CTA after Diploma -->
    <div class="mt-20 text-center animate-fade-in-up">
      <div class="flex justify-center">
        {Astro.url.pathname.includes('/us') ? (
          <button class="trigger-admission-modal cta-button px-10 py-5 text-sm tracking-[0.1em] shadow-xl hover:scale-105 transition-all">
            SOLICITAR ADMISIÓN
          </button>
        ) : (
          <a href="https://wa.me/13072923715?text=Hola%2C%20vengo%20de%20la%20p%C3%A1gina%20del%20Instituto%20Osbord%20y%20estoy%20interesado%20en%20informaci%C3%B3n%20sobre%20un%20m%C3%A1ster%20o%20curso." target="_blank" rel="noopener noreferrer" class="cta-button flex items-center justify-center gap-3 font-extrabold px-10 py-5 rounded-brand shadow-xl shadow-brand-gold/20 transition-all duration-300 hover:scale-105">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
            </svg>
            ASEGURAR MI CERTIFICACIÓN
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
</style>
