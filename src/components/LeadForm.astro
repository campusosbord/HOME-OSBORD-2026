---
interface Props {
  programName: string;
  id?: string;
}

const { programName, id = "formation-lead-form" } = Astro.props;
const city = Astro.request.headers.get('x-nf-city') || "USA (Ciudad no detectada)";
const origin = Astro.url.href;
---

<div class="bg-white p-6 lg:p-8 rounded-brand-xl shadow-elevated border border-white/10 relative overflow-hidden group">
  <div class="absolute top-0 left-0 w-full h-1 bg-brand-gold"></div>
  <div class="space-y-6">
    <div class="space-y-2 text-center w-full">
      <span class="block text-[12px] text-brand-gold font-bold uppercase tracking-[0.2em]">Admisiones Institucionales</span>
      <h2 class="text-3xl font-extrabold text-brand-navy">Solicitud de Información</h2>
      <p class="text-[14px] text-gray-500 leading-relaxed">Complete el formulario para recibir el brochure del {programName}.</p>
    </div>
    
    <form class="space-y-4" id={id}>
      <input type="hidden" name="ciudad" value={city} />
      <input type="hidden" name="origen" value={origin} />
      <input type="hidden" name="formacion" value={programName} />
      
      <div class="space-y-1.5">
        <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Nombre Completo</label>
        <input type="text" name="nombre" placeholder="Escribe tu nombre" class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="space-y-1.5">
          <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Teléfono</label>
          <input type="tel" name="telefono" placeholder="+1..." class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
        </div>
        <div class="space-y-1.5">
          <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Correo Electrónico</label>
          <input type="email" name="correo" placeholder="email@ejemplo.com" class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
        </div>
      </div>

      <div class="space-y-2 py-1">
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
        <div class="flex items-center gap-4">
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="radio" name="whatsapp" value="si" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">Sí</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="radio" name="whatsapp" value="no" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">No</span>
          </label>
        </div>
      </div>

      <div class="flex justify-center pt-2">
        <button type="submit" class="cta-button px-10 py-3 text-xs flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          RECIBIR INFORMACIÓN
        </button>
      </div>
      <p class="text-[9px] text-center text-gray-400 uppercase tracking-widest pt-2">Respuesta en menos de 24 horas</p>
    </form>
  </div>
</div>

<script is:inline define:vars={{ id }}>
  const form = document.getElementById(id);
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    try {
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwQ34SrlVoEWz_WnjoLXjmM16ubiEBKZQfjgBHWHeppjd2Elh7WA9r2UTq18lp3bbcW/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      window.osbordToast?.();
      form.reset();
    } catch (error) {
      console.error('Error:', error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
