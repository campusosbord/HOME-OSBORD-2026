---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero_professional.png';

interface Props {
  isUS?: boolean;
}

const { isUS: propIsUS } = Astro.props;
const pathname = Astro.url.pathname;
const isUS = propIsUS ?? pathname.startsWith('/us') ?? Astro.locals.isUS ?? false;
const city = Astro.locals.city || "USA (Ciudad no detectada)";
const origin = Astro.url.href;

const programs = [
  "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "Máster Ejecutivo en Organización de Eventos & Wedding Planner",
  "Curso Profesional Superior: Auxiliar de Enfermería Clínica"
];
---
<section class="relative bg-brand-navy min-h-[75vh] lg:min-h-[85vh] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Profesionales en el atrio del Instituto Online Osbord"
      class="w-full h-full object-cover opacity-25"
      width={1920}
      height={1080}
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Gradient Overlays -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/90 to-brand-navy/30"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/60 to-transparent"></div>

  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-6 py-[63px] lg:py-[85px] w-full z-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Left Column: Text -->
      <div class="space-y-8 animate-fade-in-up">
        <h1 class="uppercase tracking-tight leading-[1.1]">
          <span class="text-xl sm:text-2xl md:text-3xl lg:text-[40px] font-extrabold text-white block mb-2">
            Instituto <span class="text-brand-gold">Osbord</span>
          </span>
          <span class="text-2xl sm:text-3xl md:text-4xl lg:text-[4  0px] font-extrabold text-white block leading-tight">
            Excelencia técnica con <span class="text-brand-gold">prestigio</span> profesional global
          </span>
        </h1>

        <p class="text-lg md:text-xl text-gray-300/90 max-w-xl leading-relaxed font-light">
            Domine los estándares técnicos de élite y asegure su competitividad global. Obtenga las herramientas que el mercado demanda y acceso vitalicio a una red de networking exclusiva.
        </p>
      </div>

      <!-- Right Column: Dynamic Content -->
      <div class="relative animate-fade-in-up delay-300">
        {/* Form disabled but kept in source code as requested:
        isUS ? (
             <div class="p-6 bg-white rounded-brand-xl shadow-2xl">
                <div class="space-y-2 text-center w-full flex flex-col items-center">
                  <span class="block text-[10px] text-brand-gold font-bold uppercase tracking-widest w-full">Admisiones Institucionales</span>
                  <h2 class="text-2xl font-extrabold text-brand-navy w-full">Solicitud de Información</h2>
                </div>
                <form class="space-y-4" id="hero-contact-form">
                  <input type="hidden" name="ciudad" value={city} />
                  <input type="hidden" name="origen" value={origin} />
                  <div class="space-y-1.5">
                    <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Nombre Completo</label>
                    <input type="text" name="nombre" placeholder="Escribe tu nombre" class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                      <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Teléfono</label>
                      <input type="tel" name="telefono" placeholder="+1..." class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                      <div class="space-y-2 mt-2">
                        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
                        <div class="flex items-center gap-4">
                          <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="radio" name="whatsapp" value="si" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors">Sí</span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="radio" name="whatsapp" value="no" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors">No</span>
                          </label>
                        </div>
                      </div>
                    </div>
                    <div class="space-y-1.5">
                      <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Correo Electrónico</label>
                      <input type="email" name="correo" placeholder="email@ejemplo.com" class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                    </div>
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Programa de Interés</label>
                    <select name="formacion" class="w-full px-4 py-2.5 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm appearance-none cursor-pointer" required>
                      <option value="">Selecciona un programa</option>
                      {programs.map(p => <option value={p}>{p}</option>)}
                    </select>
                  </div>
                  <div class="flex flex-col items-center gap-3 pt-2">
                    <button type="submit" class="cta-button px-10 py-3 text-xs flex items-center gap-2">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                      INICIAR PROCESO DE ADMISIÓN
                    </button>
                    
                    <div class="flex items-center gap-2">
                      <div class="w-2 h-2 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
                      <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Respuesta en menos de 24 horas</p>
                    </div>
                  </div>
                </form>
             </div>
        ) : null
        */}

        {/* WHATSAPP BOX — con selector de programa */}
        <div class="bg-white/5 backdrop-blur-xl p-10 rounded-brand-xl border border-white/10 shadow-2xl relative group overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-gold/10 rounded-full blur-3xl group-hover:bg-brand-gold/20 transition-colors duration-500"></div>
          <div class="space-y-8 relative z-10">
            <div class="space-y-3">
              <div class="w-12 h-12 bg-brand-gold/20 rounded-brand flex items-center justify-center">
                <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <h2 class="text-3xl font-extrabold text-white">Atención <span class="text-brand-gold">Personalizada</span></h2>
              <p class="text-gray-300 leading-relaxed font-light text-sm">
                Selecciona el programa de tu interés y habla directamente con un asesor académico.
              </p>
            </div>

            <!-- Program Selector -->
            <div class="space-y-2">
              <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">Programa de Interés</label>
              <div class="relative">
                <select
                  id="hero-program-select"
                  class="w-full appearance-none bg-white/10 border border-white/20 text-white text-sm font-medium px-4 py-3 pr-10 rounded-brand focus:outline-none focus:ring-2 focus:ring-brand-gold/50 focus:border-brand-gold/50 transition-all duration-200 cursor-pointer"
                >
                  <option value="" class="bg-brand-navy text-gray-300">— Selecciona un programa —</option>
                  {programs.map(p => <option value={p} class="bg-brand-navy text-white">{p}</option>)}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                  <svg class="w-4 h-4 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>
              </div>
            </div>

            <div class="space-y-3">
              <!-- WhatsApp button — disabled until program selected -->
              <a
                id="hero-wa-btn"
                href="#"
                aria-disabled="true"
                class="group/btn flex items-center justify-center gap-3 w-full font-extrabold py-5 rounded-brand uppercase tracking-widest text-sm shadow-xl transition-all duration-300 bg-white/20 text-white/40 cursor-not-allowed pointer-events-none select-none"
              >
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
                </svg>
                Selecciona un programa primero
              </a>
              <div class="flex items-center justify-center gap-2.5">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
                <p class="text-[10px] text-gray-500 uppercase tracking-[0.2em] font-bold">Respuesta inmediata por WhatsApp</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>
</section>

<script>
  const heroForm = document.getElementById('hero-contact-form') as HTMLFormElement;
  
  // Client-side City Fallback (Plan B)
  async function resolveCity() {
    const cityInput = heroForm.querySelector('input[name="ciudad"]') as HTMLInputElement;
    // Si la ciudad no se detectó, o solo se detectó el código de país (ej. "US")
    if (cityInput && (cityInput.value.includes('no detectada') || cityInput.value.length <= 3 || !cityInput.value)) {
      try {
        const res = await fetch('https://ipapi.co/json/');
        const geo = await res.json();
        if (geo.city) {
          cityInput.value = `${geo.city}, ${geo.region} (${geo.country_name})`;
        }
      } catch (e) {
        console.warn('Geo fallback failed');
      }
    }
  }

  // Run fallback on load
  if (heroForm) resolveCity();

  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = heroForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';

    // 1. ID único para deduplicación Meta (Pixel + Conversiones API)
    const eventId = 'lead_' + Date.now() + '_' + Math.random().toString(36).slice(2, 9);
    if ((window as any).fbq) (window as any).fbq('track', 'Lead', {}, { eventID: eventId });
    if ((window as any).gtag) (window as any).gtag('event', 'generate_lead');
    
    const formData = new FormData(heroForm);
    const data: Record<string, string> = Object.fromEntries(formData.entries()) as Record<string, string>;

    // 2. Inyectar variables de seguimiento
    data.event_id = eventId;
    data.user_agent = navigator.userAgent;
    data.page_url = window.location.href;

    // 3. URLSearchParams para evitar bloqueo CORS
    const params = new URLSearchParams();
    for (const [key, value] of Object.entries(data)) {
      params.append(key, value);
    }
    
    try {
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzyWUx6b8Ys6Z6krDXOERDH7Z59iYf7--6hb6H9UHvyoSNM4mEs_ESnx1_LEwcGUuE/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        body: params
      });
      
      window.osbordToast?.();
      heroForm.reset();
    } catch (error) {
      console.error('Error:', error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });

  // ---- LATAM & US: Program selector → WhatsApp button ----
  const select = document.getElementById('hero-program-select') as HTMLSelectElement | null;
  const waBtn = document.getElementById('hero-wa-btn') as HTMLAnchorElement | null;

  if (select && waBtn) {
    select.addEventListener('change', () => {
      const program = select.value;
      if (program) {
        const isUSRoute = window.location.pathname.includes('/us/');
        const text = isUSRoute
          ? `Hola, vengo de la página de Estados Unidos del Instituto Osbord y estoy interesado en información sobre el ${program}.`
          : `Hola, vengo de la página del Instituto Osbord y estoy interesado en información sobre el ${program}.`;
        waBtn.href = `https://wa.me/13072923715?text=${encodeURIComponent(text)}`;
        waBtn.setAttribute('target', '_blank');
        waBtn.setAttribute('rel', 'noopener noreferrer');
        waBtn.removeAttribute('aria-disabled');
        waBtn.textContent = '';
        // Re-add icon + text
        waBtn.innerHTML = `<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/></svg> Hablar con un asesor`;
        // Swap classes: remove disabled look, add active style
        waBtn.classList.remove('bg-white/20', 'text-white/40', 'cursor-not-allowed', 'pointer-events-none', 'select-none');
        waBtn.classList.add('bg-[#25D366]', 'hover:bg-white', 'text-white', 'hover:text-brand-navy', 'cursor-pointer');
      } else {
        waBtn.href = '#';
        waBtn.removeAttribute('target');
        waBtn.removeAttribute('rel');
        waBtn.setAttribute('aria-disabled', 'true');
        waBtn.innerHTML = `<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/></svg> Selecciona un programa primero`;
        waBtn.classList.add('bg-white/20', 'text-white/40', 'cursor-not-allowed', 'pointer-events-none', 'select-none');
        waBtn.classList.remove('bg-[#25D366]', 'hover:bg-white', 'text-white', 'hover:text-brand-navy', 'cursor-pointer');
      }
    });
  }
</script>
