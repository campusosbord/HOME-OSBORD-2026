---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import SchoolSection from '../../components/SchoolSection.astro';
import StatsSection from '../../components/StatsSection.astro';
import ExclusivitySection from '../../components/ExclusivitySection.astro';
import Testimonials from '../../components/Testimonials.astro';
import TeachersSection from '../../components/TeachersSection.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Osbord Latam — Formación de Élite"
  description="Instituto Online Osbord. Másters con certificación internacional y atención personalizada vía WhatsApp para toda Latinoamérica."
>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <SchoolSection />
    <StatsSection />
    <ExclusivitySection />
    <TeachersSection />
    
    <CTASection
      headline="¿Listo para hablar con un asesor?"
      subtext="Atención inmediata vía WhatsApp. Resuelve tus dudas sobre becas, financiamiento y proceso de inscripción en minutos."
      buttonText="HABLAR CON UN ASESOR"
      buttonLink="https://wa.me/1234567890"
    />

    <Testimonials />
    <FAQ />
  </main>
  <Footer />
</Layout>
