---
import Logo from './Logo.astro';
import AdmissionModal from './AdmissionModal.astro';

interface Props {
  isUS?: boolean;
}

const { isUS: propIsUS } = Astro.props;
const pathname = Astro.url.pathname;
const isUS = propIsUS ?? pathname.startsWith('/us') ?? Astro.locals.isUS ?? false;
const prefix = pathname.startsWith('/us') ? '/us' : '/latam';

// Detect current master page to include program name in WhatsApp message
const programMap: Record<string, string> = {
  'enfermeria': 'Curso Profesional Superior: Auxiliar de Enfermería Clínica',
  'interiorismo': 'Máster en Interiorismo, Diseño y Decoración de Interiores 3D',
  'wedding-planner': 'Máster en Organización de Eventos & Wedding Planner + IA',
};
const masterMatch = pathname.match(/\/masters\/([^/]+)/);
const currentProgram = masterMatch ? (programMap[masterMatch[1]] ?? undefined) : undefined;
const whatsappUrl = currentProgram 
  ? `https://wa.me/13072923715?text=${encodeURIComponent(`Hola, vengo de la página del Instituto Osbord y estoy interesado en información sobre el ${currentProgram}.`)}`
  : undefined;
---
<header id="site-header" class="bg-white/95 backdrop-blur-md border-b border-gray-100/80 fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-in-out">
  <div class="max-w-7xl mx-auto px-6">
    <div id="header-container" class="flex items-center justify-between h-24 lg:h-32 transition-all duration-300 ease-in-out py-2">

      <!-- MOBILE ONLY: Admissions (Left) -->
      <div class="flex lg:hidden flex-1 justify-start items-center">
        {!isUS && currentProgram ? (
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="cta-button cta-dynamic text-[10px] px-4 py-2.5 flex items-center gap-2 scale-95 origin-left">
            ADMISIONES
          </a>
        ) : (
          <button class="trigger-admission-modal cta-button cta-dynamic text-[10px] px-4 py-2.5 flex items-center gap-2 scale-95 origin-left">
            {isUS && (
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            )}
            ADMISIONES
          </button>
        )}
      </div>

      <!-- DESKTOP ONLY: Nav Left -->
      <nav class="hidden lg:flex items-center justify-end space-x-8 flex-1" aria-label="Navegación principal">
        <a href={`${prefix}/`} class="text-sm text-brand-navy font-semibold hover:text-brand-gold transition-colors">
          Inicio
        </a>
        <!-- Institución Dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1.5 text-brand-navy font-semibold text-sm tracking-wide hover:text-brand-gold transition-colors py-6"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Institución
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-1 group-hover:translate-y-0">
            <div class="bg-white border border-gray-100 shadow-elevated rounded-brand-lg py-2 overflow-hidden">
              <a href={`${prefix}/quienes-somos`} class="flex items-center px-5 py-3 text-sm text-brand-navy hover:bg-brand-neutral hover:text-brand-gold transition-colors">
                <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                Quiénes somos
              </a>
              <a href={`${prefix}/sede-usa`} class="flex items-center px-5 py-3 text-sm text-brand-navy hover:bg-brand-neutral hover:text-brand-gold transition-colors">
                <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                Sede Estados Unidos
              </a>
              <a href={`${prefix}/metodologia`} class="flex items-center px-5 py-3 text-sm text-brand-navy hover:bg-brand-neutral hover:text-brand-gold transition-colors">
                <span class="w-1.5 h-1.5 bg-brand-gold rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                Metodología
              </a>
            </div>
          </div>
        </div>

        <!-- Oferta Académica Mega Menu -->
        <div class="static group">
          <button
            class="flex items-center gap-1.5 text-brand-navy font-semibold text-sm tracking-wide hover:text-brand-gold transition-colors py-6"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Oferta Académica
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <!-- Mega Menu Panel -->
          <div class="absolute left-0 right-0 top-full bg-white border-b border-gray-100 shadow-elevated opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <div class="max-w-7xl mx-auto grid grid-cols-3 gap-12 p-12">
              <!-- Health Sciences -->
              <div class="space-y-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-brand bg-blue-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
                    </svg>
                  </div>
                  <h3 class="text-brand-gold text-xs font-extrabold uppercase tracking-[0.2em]">Escuela de Ciencias de la Salud</h3>
                </div>
                <ul class="space-y-3 pl-[52px]">
                  <li>
                    <a href={`${prefix}/masters/enfermeria`} class="text-brand-navy hover:text-brand-gold font-medium text-sm transition-colors flex items-center group/link">
                      <span class="w-0 group-hover/link:w-3 h-px bg-brand-gold mr-0 group-hover/link:mr-2 transition-all duration-200"></span>
                      Curso Profesional Superior: Auxiliar de Enfermería Clínica
                    </a>
                  </li>
                </ul>
              </div>

              <!-- Architecture & Design -->
              <div class="space-y-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-brand bg-amber-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>
                    </svg>
                  </div>
                  <h3 class="text-brand-gold text-xs font-extrabold uppercase tracking-[0.2em]">Escuela de Arquitectura y Diseño</h3>
                </div>
                <ul class="space-y-3 pl-[52px]">
                  <li>
                    <a href={`${prefix}/masters/interiorismo`} class="text-brand-navy hover:text-brand-gold font-medium text-sm transition-colors flex items-center group/link">
                      <span class="w-0 group-hover/link:w-3 h-px bg-brand-gold mr-0 group-hover/link:mr-2 transition-all duration-200"></span>
                      Máster en Interiorismo, Diseño y Decoración de Interiores 3D
                    </a>
                  </li>
                </ul>
              </div>

              <!-- Event Management -->
              <div class="space-y-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-brand bg-rose-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
                    </svg>
                  </div>
                  <h3 class="text-brand-gold text-xs font-extrabold uppercase tracking-[0.2em]">Escuela de Gestión de Eventos</h3>
                </div>
                <ul class="space-y-3 pl-[52px]">
                  <li>
                    <a href={`${prefix}/masters/wedding-planner`} class="text-brand-navy hover:text-brand-gold font-medium text-sm transition-colors flex items-center group/link">
                      <span class="w-0 group-hover/link:w-3 h-px bg-brand-gold mr-0 group-hover/link:mr-2 transition-all duration-200"></span>
                      Máster en Organización de Eventos & Wedding Planner + IA
                    </a>
                  </li>
                </ul>
              </div>
            </div>
            {!isUS && (
              <div class="border-t border-gray-100 bg-brand-neutral/50">
                <div class="max-w-7xl mx-auto px-12 py-4 flex items-center justify-between">
                  <p class="text-xs text-gray-400 font-medium">Todos los programas incluyen certificación internacional.</p>
                  <button class="trigger-admission-modal flex items-center gap-2 text-xs font-bold text-brand-gold hover:text-brand-gold-dark transition-colors uppercase tracking-wider">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
                    </svg>
                    Solicitar información →
                    <span class="relative flex h-1.5 w-1.5 ml-1">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                    </span>
                  </button>
                </div>
              </div>
            )}
          </div>
        </div>
      </nav>

      <!-- SHARED: Centered Logo -->
      <div class="flex-shrink-0 px-4 lg:px-20 flex justify-center items-center h-full">
        <a href={`${prefix}/`} class="flex flex-col items-center group h-full justify-center" aria-label="Inicio - Instituto Online Osbord">
          <Logo id="site-logo" class="h-18 lg:h-24 w-auto group-hover:scale-105 transition-all duration-300 ease-in-out" />
        </a>
      </div>

      <!-- DESKTOP ONLY: Nav Right (with Admissions) -->
      <div class="hidden lg:flex items-center flex-1 justify-between">
        <div class="flex items-center gap-8">
          <a href={`${prefix}/verificacion`} class="lg:block text-sm text-brand-navy font-semibold hover:text-brand-gold transition-colors">
            Verificación
          </a>
          <a href={`${prefix}/contacto`} class="lg:block text-sm text-brand-navy font-semibold hover:text-brand-gold transition-colors">
            Contacto
          </a>
          <a href="https://campus.osbord.com/acceso" target="_blank" rel="noopener noreferrer" class="lg:block text-sm text-brand-navy font-semibold hover:text-brand-gold transition-colors">
            Campus Online
          </a>
        </div>
        {!isUS && currentProgram ? (
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="cta-button cta-dynamic text-xs lg:text-sm px-5 lg:px-8 flex items-center gap-2">
            ADMISIONES
          </a>
        ) : (
          <button class="trigger-admission-modal cta-button cta-dynamic text-xs lg:text-sm px-5 lg:px-8 flex items-center gap-2">
            {isUS && (
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            )}
            ADMISIONES
          </button>
        )}
      </div>

      <!-- MOBILE ONLY: Menu Toggle (Right) -->
      <div class="flex lg:hidden flex-1 justify-end items-center">
        <button id="mobile-menu-open" class="text-brand-navy p-2 hover:text-brand-gold transition-colors" aria-label="Abrir menú">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
          </svg>
        </button>
      </div>


    </div>
  </div>
</header>

<!-- Header Spacer to prevent content jump -->
<div class="h-24 lg:h-32"></div>

<!-- Mobile Sidebar Overlay (Right side slide-in) -->
<div id="mobile-sidebar" class="fixed inset-0 z-[70] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden">
  <!-- Backdrop -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-brand-navy/60 backdrop-blur-sm opacity-0 transition-opacity duration-300 z-0"></div>

  <!-- Sidebar Panel -->
  <div class="relative w-[85%] max-w-sm h-full bg-brand-navy ml-auto flex flex-col overflow-y-auto z-10">
    <div class="flex justify-between items-center p-6 border-b border-white/10">
      <div class="flex flex-col items-start">
        <Logo class="h-16 w-auto" />
      </div>
      <button id="mobile-menu-close" class="text-white/60 hover:text-white p-2 transition-colors" aria-label="Cerrar menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="flex-1 p-6 space-y-8 overflow-y-auto text-right">
      <!-- Inicio -->
      <div class="flex flex-col items-end">
        <a href={`${prefix}/`} class="block text-white/90 hover:text-brand-gold text-lg font-bold transition-colors">Inicio</a>
      </div>

      <!-- Institución -->
      <div class="space-y-4 flex flex-col items-end">
        <p class="section-label">Institución</p>
        <ul class="space-y-3">
          <li><a href={`${prefix}/quienes-somos`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors">Quiénes somos</a></li>
          <li><a href={`${prefix}/sede-usa`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors">Sede Estados Unidos</a></li>
          <li><a href={`${prefix}/metodologia`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors">Metodología</a></li>
        </ul>
      </div>

      <!-- Oferta Académica -->
      <div class="space-y-4 flex flex-col items-end">
        <p class="section-label">Oferta Académica</p>
        <ul class="space-y-3">
          <li>
            <span class="block text-white/40 text-xs uppercase tracking-widest font-bold mb-2">Escuela de Ciencias de la Salud</span>
            <a href={`${prefix}/masters/enfermeria`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors pr-4 border-r-2 border-white/10 hover:border-brand-gold">Curso Profesional Superior: Auxiliar de Enfermería Clínica</a>
          </li>
          <li>
            <span class="block text-white/40 text-xs uppercase tracking-widest font-bold mb-2 mt-4">Escuela de Arquitectura y Diseño</span>
            <a href={`${prefix}/masters/interiorismo`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors pr-4 border-r-2 border-white/10 hover:border-brand-gold">Máster en Interiorismo, Diseño y Decoración de Interiores 3D</a>
          </li>
          <li>
            <span class="block text-white/40 text-xs uppercase tracking-widest font-bold mb-2 mt-4">Escuela de Gestión de Eventos</span>
            <a href={`${prefix}/masters/wedding-planner`} class="block text-white/80 hover:text-brand-gold text-base font-medium transition-colors pr-4 border-r-2 border-white/10 hover:border-brand-gold">Máster en Organización de Eventos & Wedding Planner + IA</a>
          </li>
        </ul>
      </div>

      <div class="pt-4 border-t border-white/10 space-y-4">
        <a href={`${prefix}/verificacion`} class="block text-white/80 hover:text-brand-gold font-medium text-base transition-colors">Verificación de Títulos</a>
        <a href={`${prefix}/contacto`} class="block text-white/80 hover:text-brand-gold font-medium text-base transition-colors">Contacto</a>
        <a href="https://campus.osbord.com" target="_blank" rel="noopener noreferrer" class="block text-white/80 hover:text-brand-gold font-medium text-base transition-colors">Campus Online</a>
      </div>
    </nav>

    <div class="p-6 border-t border-white/10 mt-auto flex justify-end">
      {!isUS && currentProgram ? (
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="cta-button w-full justify-center text-center py-4 flex items-center gap-2">
          ADMISIONES
        </a>
      ) : (
        <button class="trigger-admission-modal cta-button w-full justify-center text-center py-4 flex items-center gap-2">
          {isUS && (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          )}
          ADMISIONES
        </button>
      )}
    </div>
  </div>
</div>

<AdmissionModal isUS={isUS} programName={currentProgram} />

<script>
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const sidebar = document.getElementById('mobile-sidebar');
  const backdrop = document.getElementById('mobile-backdrop');
  const header = document.getElementById('site-header');
  const headerContainer = document.getElementById('header-container');
  const logo = document.getElementById('site-logo');

  function openMenu() {
    sidebar?.classList.remove('translate-x-full');
    backdrop?.classList.remove('opacity-0');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sidebar?.classList.add('translate-x-full');
    backdrop?.classList.add('opacity-0');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  // Header effects on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-elevated', 'bg-white/98');
      header?.classList.remove('bg-white/95');
      headerContainer?.classList.remove('h-24', 'lg:h-32');
      headerContainer?.classList.add('h-20', 'lg:h-24');
      logo?.classList.remove('h-18', 'lg:h-24');
      logo?.classList.add('h-16', 'lg:h-20');
    } else {
      header?.classList.remove('shadow-elevated', 'bg-white/98');
      header?.classList.add('bg-white/95');
      headerContainer?.classList.add('h-24', 'lg:h-32');
      headerContainer?.classList.remove('h-20', 'lg:h-24');
      logo?.classList.add('h-18', 'lg:h-24');
      logo?.classList.remove('h-16', 'lg:h-20');
    }
  }, { passive: true });
</script>
