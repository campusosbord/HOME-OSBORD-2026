// Doubling the array to facilitate a "pseudo-infinite" feel with snap reset
const extendedTestimonials = [...testimonials, ...testimonials];
---

<section class="py-16 bg-brand-neutral/30 overflow-hidden" id="testimonials">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center space-y-4 mb-16">
      <span class="section-label">Casos de Éxito</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-brand-navy max-w-2xl mx-auto">
        La voz de nuestros <span class="text-brand-gold italic">egresados</span>
      </h2>
      <div class="gold-divider mx-auto"></div>
    </div>

    <div class="relative group/carousel">
      <!-- Nav Buttons -->
      <button id="prev-testimonial" class="absolute -left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-xl border border-gray-100 items-center justify-center text-brand-gold hover:bg-brand-gold hover:text-white transition-all duration-300 z-20 hidden md:flex opacity-0 group-hover/carousel:opacity-100 cursor-pointer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      
      <button id="next-testimonial" class="absolute -right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-xl border border-gray-100 items-center justify-center text-brand-gold hover:bg-brand-gold hover:text-white transition-all duration-300 z-20 hidden md:flex opacity-0 group-hover/carousel:opacity-100 cursor-pointer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>

      <!-- Track -->
      <div id="testimonials-track" class="flex gap-6 overflow-x-auto no-scrollbar pb-8 scroll-smooth">
        {extendedTestimonials.map((t) => (
          <div class="testimonial-card flex-shrink-0 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
            <div class="bg-white p-8 md:p-10 rounded-brand-xl shadow-soft border border-gray-100 h-full flex flex-col justify-between hover:shadow-elevated transition-all duration-500 group relative">
              <!-- Professional Quote Icon -->
              <div class="absolute top-8 right-8 text-brand-gold/10 group-hover:text-brand-gold/20 transition-colors pointer-events-none">
                <svg width="45" height="45" viewBox="0 0 32 32" fill="currentColor">
                  <path d="M10 12h6v6c0 3.314-2.686 6-6 6v-2c2.209 0 4-1.791 4-4h-4v-6zm12 0h6v6c0 3.314-2.686 6-6 6v-2c2.209 0 4-1.791 4-4h-4v-6z"/>
                </svg>
              </div>

              <div class="space-y-6 relative z-10">
                <div class="flex text-brand-gold gap-1">
                  {[...Array(5)].map(() => (
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <p class="text-gray-600 italic text-lg leading-relaxed">"{t.text}"</p>
              </div>

              <div class="flex items-center gap-5 mt-10 pt-8 border-t border-gray-100">
                <div class="relative flex-shrink-0">
                  <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-brand-gold/20 flex items-center justify-center bg-gray-100 aspect-square">
                    <img src={t.image} alt={t.name} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
                  </div>
                  <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-brand-gold rounded-full flex items-center justify-center border-2 border-white">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-extrabold text-brand-navy text-lg leading-tight">{t.name}</h4>
                  <p class="text-brand-gold text-[10px] font-bold uppercase tracking-widest mt-1 leading-tight">{t.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Dots -->
      <div id="pagination-dots" class="flex justify-center gap-3 mt-8">
        {testimonials.map((_, i) => (
          <button 
            class="w-2.5 h-2.5 rounded-full bg-brand-gold/20 hover:bg-brand-gold transition-all duration-300 cursor-pointer pagination-dot"
            data-index={i}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .pagination-dot.active {
    background-color: #C5A059;
    width: 2rem;
  }
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('testimonials-track');
    const prevBtn = document.getElementById('prev-testimonial');
    const nextBtn = document.getElementById('next-testimonial');
    const dots = document.querySelectorAll('.pagination-dot');
    const cards = document.querySelectorAll('.testimonial-card');

    if (!track || cards.length === 0) return;

    const originalCount = cards.length / 2;
    let currentIndex = 0;

    const getCardWidth = () => cards[0].clientWidth + 24;

    const updateCarousel = (index, smooth = true) => {
      currentIndex = index;
      track.style.scrollBehavior = smooth ? 'smooth' : 'auto';
      track.scrollTo({ left: currentIndex * getCardWidth() });
      
      // Update dots (normalized to original count)
      const dotIndex = currentIndex % originalCount;
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === dotIndex);
      });
    };

    const handleNext = () => {
      if (currentIndex >= originalCount) {
        // Instant jump to original first item
        updateCarousel(0, false);
        // Then smooth scroll to second item
        setTimeout(() => updateCarousel(1, true), 50);
      } else {
        updateCarousel(currentIndex + 1);
      }
    };

    const handlePrev = () => {
      if (currentIndex <= 0) {
        updateCarousel(originalCount, false);
        setTimeout(() => updateCarousel(originalCount - 1, true), 50);
      } else {
        updateCarousel(currentIndex - 1);
      }
    };

    // Auto-play
    let autoPlayInterval;
    const startAutoPlay = () => {
      stopAutoPlay();
      autoPlayInterval = setInterval(handleNext, 5000);
    };
    const stopAutoPlay = () => clearInterval(autoPlayInterval);

    // Nav Listeners
    nextBtn?.addEventListener('click', () => { stopAutoPlay(); handleNext(); startAutoPlay(); });
    prevBtn?.addEventListener('click', () => { stopAutoPlay(); handlePrev(); startAutoPlay(); });
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        updateCarousel(i);
        startAutoPlay();
      });
    });

    track.addEventListener('mouseenter', stopAutoPlay);
    track.addEventListener('mouseleave', startAutoPlay);

    // Sync dots on scroll
    track.addEventListener('scroll', () => {
      const scrollIndex = Math.round(track.scrollLeft / getCardWidth());
      const dotIndex = scrollIndex % originalCount;
      dots.forEach((dot, i) => dot.classList.toggle('active', i === dotIndex));
    });

    startAutoPlay();
  }

  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>
