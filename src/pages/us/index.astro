---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import SchoolSection from '../../components/SchoolSection.astro';
import StatsSection from '../../components/StatsSection.astro';
import ExclusivitySection from '../../components/ExclusivitySection.astro';
import TeachersSection from '../../components/TeachersSection.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTASection from '../../components/CTASection.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import AdmissionModal from '../../components/AdmissionModal.astro';

const city = Astro.request.headers.get('x-nf-city') || "USA (Ciudad no detectada)";
const origin = Astro.url.href;
---

<Layout 
  title="Admisiones Institucionales | Instituto Online Osbord"
  description="Inicie su proceso de admisión en el Instituto Online Osbord. Programas de máster con certificación internacional y excelencia académica."
>
  <Header />
  <main>
    <Hero isUS={true} />
    <TrustBar />
    <SchoolSection />
    <StatsSection />
    <ExclusivitySection />
    <TeachersSection />

    <!-- Seccion de Formulario para USA -->
    <section id="contacto-usa" class="py-24 bg-brand-neutral">
      <div class="max-w-4xl mx-auto px-6 relative">
        <div class="bg-white p-8 sm:p-10 rounded-brand-xl shadow-elevated border border-gray-100">
          <div class="text-center mb-10 space-y-3">
            <span class="block text-[12px] text-brand-gold font-bold uppercase tracking-[0.2em] text-center">Admisión Institucional</span>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-center">Solicitud de Información</h2>
            <p class="text-gray-500 text-[16px] leading-relaxed text-center">Complete el siguiente formulario para recibir nuestro brochure institucional y los requisitos de admisión.</p>
          </div>
          <form class="space-y-6" id="index-contact-form">
            <input type="hidden" name="ciudad" value={city} />
            <input type="hidden" name="origen" value={origin} />
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Nombre Completo</label>
                <input type="text" name="nombre" placeholder="Ej. Juan Pérez" class="w-full px-5 py-2.5 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Correo Electrónico</label>
                <input type="email" name="correo" placeholder="email@ejemplo.com" class="w-full px-5 py-2.5 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Teléfono</label>
                <input type="tel" name="telefono" placeholder="+1..." class="w-full px-5 py-2.5 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                
                <div class="space-y-2 mt-4">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
                  <div class="flex items-center gap-6">
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="whatsapp" value="si" class="w-4 h-4 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-xs font-bold text-brand-navy uppercase tracking-wider group-hover:text-brand-gold transition-colors">Sí</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="whatsapp" value="no" class="w-4 h-4 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-xs font-bold text-brand-navy uppercase tracking-wider group-hover:text-brand-gold transition-colors">No</span>
                    </label>
                  </div>
                </div>
              </div>
              
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Programa de Interés</label>
                <select name="formacion" class="w-full px-5 py-2.5 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all bg-white text-sm" required>
                  <option value="" disabled selected>Selecciona un programa</option>
                  <option>Máster en Interiorismo, Diseño y Decoración de Interiores 3D</option>
                  <option>Máster en Organización de Eventos & Wedding Planner + IA</option>
                  <option>CURSO PROFESIONAL SUPERIOR: AUXILIAR DE ENFERMERÍA CLÍNICA</option>
                </select>
              </div>
            </div>

            <div class="pt-6 flex justify-center">
              <button type="submit" class="cta-button px-12 py-3 text-xs">ENVIAR SOLICITUD DE ADMISIÓN</button>
            </div>
            <p class="text-[9px] text-center text-gray-400 mt-4 uppercase tracking-[0.2em] font-medium">Procesamiento de solicitud prioritario</p>
          </form>
        </div>
      </div>
    </section>

    <CTASection 
      headline="Comience su Transformación Hoy"
      subtext="Hable con un asesor de admisiones para conocer nuestras becas parciales disponibles para este ciclo."
      variant="dark"
    />

    <Testimonials />

    <section class="py-20 bg-brand-neutral/50">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight">Preguntas Frecuentes</h2>
        </div>
        <FAQ />
      </div>
    </section>

    <AdmissionModal isUS={true} />
  </main>
  <Footer />
</Layout>

<script>
  const contactForm = document.getElementById('index-contact-form') as HTMLFormElement;
  
  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    
    const formData = new FormData(contactForm);
    const data = Object.fromEntries(formData.entries());
    
    try {
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwQ34SrlVoEWz_WnjoLXjmM16ubiEBKZQfjgBHWHeppjd2Elh7WA9r2UTq18lp3bbcW/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      window.osbordToast?.();
      contactForm.reset();
    } catch (error) {
      console.error('Error:', error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
