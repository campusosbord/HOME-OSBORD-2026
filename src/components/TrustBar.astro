---
const badges = [
  {
    label: "SEDE ESTADOS UNIDOS",
    sublabel: "Instituto Registrado",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`
  },
  {
    label: "APOSTILLA DE LA HAYA",
    sublabel: "Validez Internacional",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.467.732-3.559"/></svg>`
  },
  {
    label: "NETWORKING",
    sublabel: "Comunidad de Alumnos",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>`
  },
  {
    label: "BOLSA LABORAL",
    sublabel: "CONEXIÓN PROFESIONAL",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`
  }
];
---

<section class="bg-white py-16 border-b border-gray-100/80">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-10">
      <p class="section-label">Beneficios De Estudiar en el instituto osbord</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {badges.map((badge) => (
        <div class="glass-card rounded-brand-lg p-6 text-center group hover:shadow-elevated transition-all duration-300 hover:-translate-y-1 cursor-default">
          <div class="flex justify-center mb-3">
            <div class="w-12 h-12 rounded-full bg-brand-neutral flex items-center justify-center text-brand-navy group-hover:text-brand-gold group-hover:bg-brand-gold/10 transition-all duration-300" set:html={badge.icon} />
          </div>
          <p class="text-xs font-extrabold text-brand-navy tracking-wider uppercase">{badge.label}</p>
          <p class="text-[10px] text-gray-400 font-medium mt-1 uppercase tracking-wider">{badge.sublabel}</p>
        </div>
      ))}
    </div>
  </div>
</section>
