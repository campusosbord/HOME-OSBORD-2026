---
import AccreditationBadge from './AccreditationBadge.astro';
interface Props {
  isUS?: boolean;
}

const { isUS } = Astro.props;
const city = Astro.request.headers.get('x-nf-city') || "Unknown City";

const programs = [
  "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "Máster en Organización de Eventos & Wedding Planner + IA",
  "CURSO PROFESIONAL SUPERIOR: AUXILIAR DE ENFERMERÍA CLÍNICA"
];
---

<div id="admission-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-brand-navy/80 backdrop-blur-sm transition-opacity" id="modal-backdrop"></div>

  <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
    <div class="relative transform overflow-hidden rounded-brand-xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-xl animate-scale-in">
      <AccreditationBadge variant="gold" className="absolute top-4 left-4 z-20 scale-50 sm:scale-75 origin-top-left" />
      
      <!-- Close Button -->
      <button id="close-modal" class="absolute top-6 right-6 text-gray-400 hover:text-brand-navy transition-colors z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      {isUS ? (
        /* US VERSION: Institutional Form */
        <div class="p-8 sm:p-12">
          <div class="text-center mb-10 space-y-3">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-gold">Proceso de Admisión</span>
            <h3 class="text-3xl font-extrabold text-brand-navy tracking-tight" id="modal-title">Solicitud de Información</h3>
            <p class="text-gray-500 text-sm">Complete el formulario institucional para iniciar su proceso de admisión.</p>
          </div>

          <form class="space-y-5" id="admission-form">
            <input type="hidden" name="city" value={city} />
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Nombre Completo</label>
              <input type="text" placeholder="Ej. Juan Pérez" class="w-full px-5 py-4 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-brand-navy placeholder:text-gray-300" />
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Teléfono</label>
                <input type="tel" placeholder="+1..." class="w-full px-5 py-4 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-brand-navy placeholder:text-gray-300" required />
                <div class="space-y-2 mt-2">
                  <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
                  <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="modal-whatsapp" value="si" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">Sí</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input type="radio" name="modal-whatsapp" value="no" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                      <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">No</span>
                    </label>
                  </div>
                </div>
              </div>
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Correo Electrónico</label>
                <input type="email" placeholder="email@ejemplo.com" class="w-full px-5 py-4 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-brand-navy placeholder:text-gray-300" required />
              </div>
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Programa de Interés</label>
              <select class="w-full px-5 py-4 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-brand-navy appearance-none" required>
                <option value="" disabled selected>Seleccione un programa</option>
                {programs.map(p => <option value={p}>{p}</option>)}
              </select>
            </div>

            <div class="pt-4">
              <button type="submit" class="cta-button w-full justify-center py-5 shadow-lg shadow-brand-gold/20">
                ENVIAR SOLICITUD DE ADMISIÓN
              </button>
              <p class="text-[10px] text-center text-gray-400 mt-4 uppercase tracking-widest font-medium">Respuesta garantizada en menos de 24 horas hábiles</p>
            </div>
          </form>
        </div>
      ) : (
        /* LATAM VERSION: Elegant WhatsApp Box */
        <div class="p-0 overflow-hidden">
          <div class="bg-brand-navy p-10 text-center space-y-4">
             <div class="w-16 h-16 bg-brand-gold/10 rounded-full flex items-center justify-center mx-auto mb-2">
                <svg class="w-8 h-8 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                </svg>
             </div>
             <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-gold">Atención Personalizada</span>
             <h3 class="text-3xl font-extrabold text-white tracking-tight">Consultoría Académica</h3>
             <p class="text-gray-400 text-sm max-w-sm mx-auto">Conecta directamente con un asesor de admisiones para resolver tus dudas sobre becas, financiamiento y programas.</p>
          </div>
          
          <div class="p-10 bg-white">
            <div class="space-y-6">
              <div class="flex items-center gap-4 p-4 rounded-brand-lg bg-brand-neutral border border-gray-100">
                <div class="w-12 h-12 rounded-full overflow-hidden flex-shrink-0 border-2 border-white shadow-sm">
                  <img src="https://ui-avatars.com/api/?name=Osbord+Admissions&background=C5A059&color=fff" alt="Advisor" class="w-full h-full object-cover" />
                </div>
                <div>
                  <p class="text-sm font-bold text-brand-navy">Departamento de Admisiones</p>
                  <p class="text-xs text-brand-gold font-medium uppercase tracking-wider">En línea ahora</p>
                </div>
              </div>

              <div class="space-y-4">
                <p class="text-sm text-gray-500 leading-relaxed italic text-center px-4">
                  "Estamos listos para guiarte en tu próximo gran paso profesional. Haz clic abajo para iniciar una conversación privada vía WhatsApp."
                </p>
                <a href="https://wa.me/1234567890" class="flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#20ba5a] text-white font-extrabold py-5 rounded-brand shadow-xl shadow-green-500/20 transition-all duration-300 transform hover:-translate-y-1">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  </svg>
                  INICIAR CONSULTA POR WHATSAPP
                </a>
                <p class="text-[10px] text-center text-gray-400 uppercase tracking-widest font-bold">Respuesta inmediata · Sin compromiso</p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-scale-in {
    animation: scale-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  const modal = document.getElementById('admission-modal');
  const closeBtn = document.getElementById('close-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const triggers = document.querySelectorAll('.trigger-admission-modal');

  function openModal(e: Event) {
    e.preventDefault();
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // Close mobile menu if open
    const sidebar = document.getElementById('mobile-sidebar');
    const backdrop = document.getElementById('mobile-backdrop');
    if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
      sidebar.classList.add('-translate-x-full');
      backdrop?.classList.add('opacity-0');
      backdrop?.classList.remove('opacity-100');
    }
  }

  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', openModal);
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // Close on Escape
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
  // Form Submission Logic
  const admissionForm = document.getElementById('admission-form') as HTMLFormElement;
  
  admissionForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = admissionForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    
    const formData = new FormData(admissionForm);
    const data = Object.fromEntries(formData.entries());
    
    try {
      // Reemplaza con la URL real de tu Google Apps Script
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbz_XXXXXXXXX/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      alert('¡Gracias! Tu solicitud de admisión ha sido enviada correctamente.');
      admissionForm.reset();
      closeModal();
    } catch (error) {
      console.error('Error:', error);
      alert('Hubo un error al enviar el formulario. Por favor, intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
