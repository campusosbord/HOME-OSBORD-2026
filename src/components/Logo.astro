---
import { Image } from 'astro:assets';
import logoImage from '../assets/Instituto Osbord logo.webp';

interface Props {
  class?: string;
  id?: string;
  light?: boolean;
}

const { class: className, id, light = false } = Astro.props;
---

<Image 
  src={logoImage} 
  alt="Instituto Online Osbord" 
  id={id}
  class:list={[
    "object-contain",
    className
  ]}
  loading="eager"
/>



