---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
---

<Layout
  title="Sede Estados Unidos"
  description="Instituto Online Osbord está registrado en Estados Unidos. Conoce nuestra estructura institucional internacional."
>
  <Header />
  <main>
    <section class="bg-brand-navy py-20 lg:py-24 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-navy to-brand-navy-light"></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/us/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li>/</li>
            <li class="text-brand-gold font-semibold">Sede Estados Unidos</li>
          </ol>
        </nav>
        <div class="max-w-3xl space-y-6 animate-fade-in-up">
          <span class="section-label">Presencia Internacional</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] tracking-tight">
            Sede <span class="text-brand-gold">Estados Unidos</span>
          </h1>
          <p class="text-lg text-gray-300 max-w-xl leading-relaxed">
            Nuestra estructura legal en Estados Unidos garantiza transparencia, seriedad institucional y validez internacional de todos nuestros programas.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div class="space-y-8">
            <div class="space-y-4">
              <span class="section-label">Estructura Legal</span>
              <h2 class="text-3xl font-extrabold tracking-tight">Empresa Registrada en Estados Unidos</h2>
              <div class="gold-divider"></div>
            </div>
            <p class="text-gray-500 leading-relaxed text-lg">Instituto Online Osbord opera como una Limited Liability Company (LLC) constituida bajo las leyes de los Estados Unidos. Esta estructura legal garantiza a nuestros estudiantes el respaldo y la seguridad de una entidad sujeta a los estándares de transparencia y cumplimiento del sistema norteamericano.</p>
          </div>

          <div class="space-y-6">
            <div class="p-8 bg-brand-neutral rounded-brand-xl border border-gray-100 space-y-6">
              <h3 class="font-extrabold text-lg">Datos Corporativos</h3>
              <ul class="space-y-5">
                <li class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21"/></svg>
                  <div>
                    <p class="font-bold text-sm text-brand-navy">Razón Social</p>
                    <p class="text-gray-500 text-sm">Instituto Online Osbord LLC</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                  <div>
                    <p class="font-bold text-sm text-brand-navy">Dirección</p>
                    <p class="text-gray-500 text-sm">30 N Gould St Ste N, Sheridan, WY 82801, USA</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path>
                    <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path>
                    <path d="M7 21h10"></path>
                    <path d="M12 3v18"></path>
                    <path d="M3 7h18"></path>
                  </svg>
                  <div>
                    <p class="font-bold text-sm text-brand-navy">Jurisdicción</p>
                    <p class="text-gray-500 text-sm">Estado de Wyoming, Estados Unidos</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <path d="m9 12 2 2 4-4"></path>
                  </svg>
                  <div>
                    <p class="font-bold text-sm text-brand-navy">Alcance</p>
                    <p class="text-gray-500 text-sm">Institución con estándares de cumplimiento y transparencia de los Estados Unidos.</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTASection headline="¿Tienes preguntas sobre nuestra estructura legal?" subtext="Nuestro equipo de admisiones puede responder cualquier consulta sobre la validez de nuestros diplomas y certificaciones." buttonText="SOLICITAR ADMISIÓN" />
  </main>
  <Footer />
</Layout>
