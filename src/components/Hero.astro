---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero_professional.png';
import AccreditationBadge from './AccreditationBadge.astro';

interface Props {
  isUS?: boolean;
}

const { isUS: propIsUS } = Astro.props;
const isUS = propIsUS ?? Astro.locals.isUS ?? false;
const city = Astro.request.headers.get('x-nf-city') || "Unknown City";

const programs = [
  "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "Máster en Organización de Eventos & Wedding Planner + IA",
  "Máster en Auxiliar de Enfermería Clínica"
];
---
<section class="relative bg-brand-navy min-h-[90vh] lg:min-h-screen flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Profesionales en el atrio del Instituto Online Osbord"
      class="w-full h-full object-cover opacity-25"
      width={1920}
      height={1080}
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Gradient Overlays -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/90 to-brand-navy/30"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/60 to-transparent"></div>

  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-6 py-20 lg:py-0 w-full z-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Left Column: Text -->
      <div class="space-y-8 animate-fade-in-up">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.08] tracking-tight">
          Liderazgo Académico
          <br />
          <span class="text-brand-gold">de Alto Impacto</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-300/90 max-w-xl leading-relaxed font-light">
          Formación de élite diseñada para profesionales que buscan autoridad, certificación internacional y excelencia técnica en un mercado global competitivo.
        </p>

        <!-- Trust Badges -->
        <div class="flex flex-wrap items-center gap-x-8 gap-y-6 pt-6">
          <div class="flex items-center gap-3 group">
            <div class="w-1.5 h-1.5 rounded-full bg-brand-gold group-hover:scale-150 transition-transform duration-300"></div>
            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-[0.2em]">Sede Estados Unidos</span>
          </div>
          <div class="flex items-center gap-3 group">
            <div class="w-1.5 h-1.5 rounded-full bg-brand-gold group-hover:scale-150 transition-transform duration-300"></div>
            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-[0.2em]">Sede Venezuela</span>
          </div>
          <div class="flex items-center gap-3 group">
            <div class="w-1.5 h-1.5 rounded-full bg-brand-gold group-hover:scale-150 transition-transform duration-300"></div>
            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-[0.2em]">100% Online</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Dynamic Content -->
      <div class="relative animate-fade-in-up delay-300">
        {isUS ? (
          /* FORMULARIO USA (EN ESPAÑOL) */
          <div id="contacto-usa" class="bg-white p-8 lg:p-10 rounded-brand-xl shadow-elevated border border-white/10 relative overflow-hidden group">
             <div class="absolute top-0 left-0 w-full h-1 bg-brand-gold"></div>
             <AccreditationBadge className="absolute -top-4 -right-4 z-20 scale-75 md:scale-100" />
             <div class="space-y-6">
                <div class="space-y-2">
                  <span class="text-[10px] text-brand-gold font-bold uppercase tracking-widest">Admisiones Institucionales</span>
                  <h2 class="text-2xl font-extrabold text-brand-navy">Solicitud de Información</h2>
                </div>
                <form class="space-y-4" id="hero-contact-form">
                  <input type="hidden" name="city" value={city} />
                  <div class="space-y-1.5">
                    <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Nombre Completo</label>
                    <input type="text" placeholder="Escribe tu nombre" class="w-full px-4 py-3 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                      <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Teléfono</label>
                      <input type="tel" placeholder="+1..." class="w-full px-4 py-3 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                      <div class="space-y-2 mt-2">
                        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
                        <div class="flex items-center gap-4">
                          <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="radio" name="hero-whatsapp" value="si" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors">Sí</span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="radio" name="hero-whatsapp" value="no" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors">No</span>
                          </label>
                        </div>
                      </div>
                    </div>
                    <div class="space-y-1.5">
                      <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Correo Electrónico</label>
                      <input type="email" placeholder="email@ejemplo.com" class="w-full px-4 py-3 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm" required />
                    </div>
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-[10px] font-bold uppercase text-gray-400 tracking-wider">Programa de Interés</label>
                    <select class="w-full px-4 py-3 bg-brand-neutral border border-gray-100 rounded-brand focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all text-sm appearance-none cursor-pointer" required>
                      <option value="">Selecciona un programa</option>
                      {programs.map(p => <option value={p}>{p}</option>)}
                    </select>
                  </div>
                  <button type="submit" class="cta-button w-full justify-center py-4 text-sm mt-2">
                    INICIAR PROCESO DE ADMISIÓN
                  </button>
                  <p class="text-[9px] text-center text-gray-400 uppercase tracking-widest pt-2">Se requiere verificación institucional</p>
                </form>
             </div>
          </div>
        ) : (
          /* WHATSAPP BOX LATAM */
          <div class="bg-white/5 backdrop-blur-xl p-10 rounded-brand-xl border border-white/10 shadow-2xl relative group overflow-hidden">
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-gold/10 rounded-full blur-3xl group-hover:bg-brand-gold/20 transition-colors duration-500"></div>
            <div class="space-y-8 relative z-10">
              <div class="space-y-3">
                <div class="w-12 h-12 bg-brand-gold/20 rounded-brand flex items-center justify-center">
                  <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-white">Atención <span class="text-brand-gold">Personalizada</span></h2>
                <p class="text-gray-300 leading-relaxed font-light">
                  ¿Deseas conocer más sobre nuestras becas y planes de financiamiento? Contacta ahora con un asesor académico para una consultoría gratuita.
                </p>
              </div>

              <div class="space-y-4">
                <a href="https://wa.me/1234567890" class="flex items-center justify-center gap-3 w-full bg-brand-gold text-brand-navy font-extrabold py-5 rounded-brand hover:bg-white transition-all duration-300 uppercase tracking-widest text-sm shadow-xl hover:shadow-brand-gold/20">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  </svg>
                  Hablar con un asesor
                </a>
                <p class="text-[10px] text-center text-gray-500 uppercase tracking-[0.2em] font-bold">Respuesta inmediata por WhatsApp</p>
              </div>
            </div>
          </div>
        )}
      </div>

    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>
</section>

<script>
  const heroForm = document.getElementById('hero-contact-form') as HTMLFormElement;
  
  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = heroForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    
    const formData = new FormData(heroForm);
    const data = Object.fromEntries(formData.entries());
    
    try {
      // Reemplaza con la URL real de tu Google Apps Script
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbz_XXXXXXXXX/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      alert('¡Gracias! Tu solicitud de admisión ha sido enviada correctamente.');
      heroForm.reset();
    } catch (error) {
      console.error('Error:', error);
      alert('Hubo un error al enviar el formulario. Por favor, intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
