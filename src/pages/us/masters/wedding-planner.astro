---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CourseAccordion from '../../../components/CourseAccordion.astro';
import Testimonials from '../../../components/Testimonials.astro';
import FAQ from '../../../components/FAQ.astro';
import CTASection from '../../../components/CTASection.astro';
import TeachersSection from '../../../components/TeachersSection.astro';
import AccreditationBadge from '../../../components/AccreditationBadge.astro';
import { Image } from 'astro:assets';
import eventsImg from '../../../assets/school_events.png';
import LeadForm from '../../../components/LeadForm.astro';
import WhatsAppBox from '../../../components/WhatsAppBox.astro';
import BenefitsSection from '../../../components/BenefitsSection.astro';
import DiplomaSection from '../../../components/DiplomaSection.astro';

const isUS = true;
const programName = "Wedding Planner & IA";
const formationFullName = "Máster en Organización de Eventos & Wedding Planner + IA";

const benefits = [
  {
    title: "Eventos de Autor",
    description: "Aprende a diseñar bodas y eventos con un sello distintivo de exclusividad, dominando el protocolo y las últimas tendencias de lujo.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>',
    tag: "Exclusividad"
  },
  {
    title: "IA Aplicada",
    description: "Optimiza tu tiempo y creatividad utilizando Inteligencia Artificial para el diseño de conceptos, moodboards y gestión logística eficiente.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v1.244c0 .462.223.9.605 1.17l.999.713a1.123 1.123 0 001.292 0l.999-.713a1.5 1.5 0 01.605-1.17V3.104a3.75 3.75 0 00-4.5 0zM21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 3h6m-6-6h6"/></svg>',
    tag: "Tecnología"
  },
  {
    title: "Certificación USA",
    description: "Obtén un título con respaldo internacional de nuestra sede en USA, garantizando los estándares más altos de la industria global.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84a51.39 51.39 0 00-2.658.814m-15.482 0l12.93 3.317a.5.5 0 00.254 0l12.93-3.317m-12.93 3.317V16.5"/></svg>',
    tag: "Internacional"
  },
  {
    title: "Negocio Propio",
    description: "Te entregamos las herramientas empresariales necesarias para lanzar y gestionar tu propia agencia de eventos con alta rentabilidad.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>',
    tag: "Emprendimiento"
  },
  {
    title: "Prestigio Global",
    description: "Forma parte de una élite de organizadores certificados, capacitados para trabajar en cualquier parte del mundo con estándares premium.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21l-8.25-1.875V7.03L12 3l8.25 4.03v12.095L12 21z"/></svg>',
    tag: "Estatus"
  },
  {
    title: "Networking de Lujo",
    description: "Accede a una red exclusiva de proveedores, venues y profesionales del sector nupcial internacional para potenciar tus eventos.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>',
    tag: "Contactos"
  }
];

const syllabus = [
  { 
    title: "Módulo 1: Organización de Eventos", 
    content: [
      "Comunicación",
      "Cultura Corporativa",
      "Planificación",
      "Marketing",
      "Realización",
      "Tipos de Eventos",
      "Montaje de Tarimas",
      "Dirección y Control",
      "Perfil del Event Manager",
      "Briefing y Presupuesto",
      "Protocolo y Seguridad",
      "Recursos Masivos",
      "Post-Evento",
      "Herramientas",
      "Administración Presupuestaria",
      "Examen de Evaluación: Módulo 1."
    ]
  },
  { 
    title: "Módulo 2: Protocolo y Etiqueta Nupcial", 
    content: [
      "Normas de Protocolo Internacional",
      "Etiqueta y Vestimenta (Dress Code)",
      "Heráldica y Vexilología Nupcial",
      "Precedencias y Jerarquías",
      "Ceremonias Religiosas y Civiles",
      "Protocolo en Banquetes",
      "Discursos y Brindis",
      "Regalos y Listas de Bodas",
      "Gestión de Invitados VIP",
      "Examen de Evaluación: Módulo 2."
    ]
  },
  { 
    title: "Módulo 3: Diseño y Decoración de Eventos", 
    content: [
      "Teoría del Color Aplicada",
      "Diseño de Moodboards",
      "Escenografía y Ambientación",
      "Diseño Floral y Centros de Mesa",
      "Iluminación Decorativa",
      "Mobiliario y Menaje",
      "Gráfica y Papelería Nupcial",
      "Tendencias en Interiorismo",
      "Styling de Espacios",
      "Examen de Evaluación: Módulo 3."
    ]
  },
  { 
    title: "Módulo 4: Producción y Logística", 
    content: [
      "Cronograma del Evento (Timing)",
      "Gestión de Proveedores (Sourcing)",
      "Logística de Transportes",
      "Coordinación del 'Día D'",
      "Gestión de Contingencias",
      "Seguridad y Riesgos",
      "Montajes y Desmontajes",
      "Gestión de Equipos de Trabajo",
      "Checklist de Producción",
      "Examen de Evaluación: Módulo 4."
    ]
  },
  { 
    title: "Módulo 5: Gastronomía y Catering", 
    content: [
      "Tipos de Servicio de Mesa",
      "Elaboración de Menús de Lujo",
      "Maridaje y Bodega",
      "Coctelería y Welcome Drink",
      "Candy Bar y Tartas Nupciales",
      "Gestión de Alergias y Dietas Especiales",
      "Food Styling",
      "Contratación de Catering Externo",
      "Examen de Evaluación: Módulo 5."
    ]
  },
  { 
    title: "Módulo 6: Marketing y Branding para WP", 
    content: [
      "Posicionamiento de Marca Personal",
      "Marketing de Servicios de Lujo",
      "Estrategia en Redes Sociales",
      "Publicidad en Google y Facebook Ads",
      "Relaciones Públicas",
      "Venta y Negociación",
      "Captación de Clientes High-Ticket",
      "Portfolio Profesional",
      "Examen de Evaluación: Módulo 6."
    ]
  },
  { 
    title: "Módulo 7: Gestión Financiera y Legal", 
    content: [
      "Estructura de Costes",
      "Elaboración de Presupuestos",
      "Contratos con Clientes",
      "Seguros de Responsabilidad Civil",
      "Facturación y Fiscalidad",
      "Negociación con Proveedores",
      "Modelos de Negocio WP",
      "Examen de Evaluación: Módulo 7."
    ]
  },
  { 
    title: "Módulo 8: Fotografía y Vídeo Nupcial", 
    content: [
      "Dirección Artística de Sesiones",
      "Storytelling Visual",
      "Formatos de Vídeo Modernos",
      "Selección de Profesionales",
      "Post-Producción Visual",
      "Derechos de Imagen",
      "Tendencias en Álbumes Digitales",
      "Examen de Evaluación: Módulo 8."
    ]
  },
  { 
    title: "Módulo 9: Destination Weddings", 
    content: [
      "Mercado de Bodas Destino",
      "Logística de Viajes e Invitados",
      "Trámites Legales Internacionales",
      "Cultural Awareness (Bodas Étnicas)",
      "Gestión de Alojamiento",
      "Actividades Complementarias",
      "Contratación Local vs. Global",
      "Examen de Evaluación: Módulo 9."
    ]
  },
  { 
    title: "Módulo 10: Proyecto Final de Maestría", 
    content: [
      "Definición del Briefing del Cliente",
      "Desarrollo del Concepto Creativo",
      "Planificación Logística Integral",
      "Presupuesto Detallado",
      "Dossier de Presentación Profesional",
      "Defensa ante el Tribunal Académico",
      "Evaluación Final de Grado."
    ]
  }
];


const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Máster en Organización de Eventos & Wedding Planner + IA",
  "description": "Formación profesional en organización de bodas y eventos de lujo. Protocolo, diseño, logística y marketing digital con certificación internacional.",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Instituto Online Osbord",
    "url": "https://osbord.edu"
  },
  "educationalLevel": "Máster",
  "numberOfCredits": 60,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT600H"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://osbord.edu" },
    { "@type": "ListItem", "position": 2, "name": "Escuela de Gestión de Eventos", "item": "https://osbord.edu/escuela/eventos" },
    { "@type": "ListItem", "position": 3, "name": "Máster en Organización de Eventos & Wedding Planner + IA", "item": "https://osbord.edu/masters/wedding-planner" }
  ]
};
---

<Layout
  title="Máster en Organización de Eventos & Wedding Planner + IA"
  description="Conviértete en un experto en organización de bodas y eventos de lujo con Inteligencia Artificial. Certificación internacional con diploma apostillado."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header />
  <main>
    <!-- Course Hero -->
    <section class="bg-brand-navy py-24 lg:py-32 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-40">
        <Image src={eventsImg} alt="Wedding Planning Profesional" class="w-full h-full object-cover" width={1920} height={1080} loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/60 to-transparent"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="mb-12" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/us/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/us/escuela/eventos" class="hover:text-brand-gold transition-colors">Gestión de Eventos</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-gold font-semibold uppercase text-[10px] tracking-widest">WEDDING PLANNER & EVENTOS</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8 animate-fade-in-up">
            <span class="section-label">Escuela de Gestión de Eventos</span>
            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight uppercase">
              MÁSTER EN <span class="text-brand-gold">WEDDING PLANNER</span>
            </h1>
            <div class="flex items-center gap-4">
              <div class="w-12 h-1 bg-brand-gold"></div>
              <p class="text-xl text-white font-bold tracking-widest uppercase">
                & Organización de Eventos + IA
              </p>
            </div>
            <p class="text-lg text-gray-200 max-w-lg leading-relaxed">
              Domina el arte de crear bodas y eventos inolvidables con el apoyo de herramientas de IA. Protocolo, diseño y gestión empresarial para el mercado del lujo.
            </p>

            <!-- Stats Row -->
            <div class="flex flex-wrap items-center gap-8 pt-4">
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">10</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Módulos</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">USA</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Certificación</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">Online</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Modalidad</p>
              </div>
            </div>
          </div>

          <!-- Form Side (US) or WhatsApp (Latam) -->
          <div class="relative animate-fade-in-up delay-300">
            <div class="absolute -top-10 -right-6 z-20">
              <AccreditationBadge className="scale-75 md:scale-90" />
            </div>
            {isUS ? (
              <LeadForm programName={formationFullName} />
            ) : (
              <WhatsAppBox programName={programName} />
            )}
          </div>
        </div>
      </div>
    </section>


    <!-- Syllabus Section -->
    <section class="section-padding bg-white">
      <div class="grid lg:grid-cols-3 gap-16">
        <div class="lg:col-span-1 space-y-6">
          <p class="section-label">Plan de Estudios</p>
          <h2 class="text-3xl font-extrabold tracking-tight">Programa Académico</h2>
          <div class="gold-divider"></div>
          <p class="text-gray-500 leading-relaxed">
            Un programa diseñado para convertirte en un profesional integral de la organización de eventos de lujo a nivel internacional.
          </p>

          <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
            <h4 class="font-extrabold text-sm uppercase tracking-wider">¿Qué incluye?</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Kit de herramientas de planificación.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Plantillas de presupuesto profesionales.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Diploma apostillado por la Haya.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Red de contactos de proveedores premium.
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-2">
          <CourseAccordion syllabus={syllabus} />
        </div>
      </div>
    </section>

    <BenefitsSection formationName={programName} benefits={benefits} />

    <TeachersSection limitTo={["Raul Ramirez"]} />
    <DiplomaSection />
    <Testimonials />
    <FAQ />

    <CTASection
      variant="dark"
      headline="Crea eventos que dejen huella"
      subtext="Únete a la próxima cohorte del Máster en Wedding Planner y posiciónate como referente en la industria nupcial internacional."
      buttonText="SOLICITAR ADMISIÓN"
    />
  </main>
  <Footer />
</Layout>
