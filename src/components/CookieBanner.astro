---
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 p-4 md:p-6 translate-y-full transition-transform duration-500 ease-out hidden">
  <div class="max-w-7xl mx-auto bg-brand-navy/95 backdrop-blur-md text-white rounded-brand-xl p-6 md:p-8 border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.3)] flex flex-col lg:flex-row items-center justify-between gap-6">
    <div class="space-y-2 max-w-3xl">
      <h3 class="text-brand-gold font-extrabold text-lg uppercase tracking-wider flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Consentimiento de Cookies
      </h3>
      <p class="text-sm text-gray-300 leading-relaxed">
        Utilizamos cookies propias y de terceros para optimizar el rendimiento del Campus Virtual, realizar estadísticas de navegación y personalizar nuestra publicidad. Al hacer clic en "Aceptar todo", consientes el uso de todas ellas. Puedes consultar todos los detalles en nuestra <a href="/cookies" class="text-brand-gold underline hover:text-white transition-colors font-semibold">Política de Cookies</a>.
      </p>
    </div>
    
    <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto justify-end">
      <button id="btn-cookie-reject" class="px-5 py-2.5 rounded-brand-lg border border-white/20 text-xs font-bold uppercase tracking-wider hover:bg-white/10 transition-all w-full sm:w-auto text-center">
        Rechazar
      </button>
      <button id="btn-cookie-accept" class="px-6 py-2.5 rounded-brand-lg bg-brand-gold hover:bg-white hover:text-brand-navy text-brand-navy text-xs font-bold uppercase tracking-wider transition-all duration-300 w-full sm:w-auto text-center shadow-lg shadow-brand-gold/20">
        Aceptar todo
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('btn-cookie-accept');
    const rejectBtn = document.getElementById('btn-cookie-reject');

    if (!banner || !acceptBtn || !rejectBtn) return;

    // Check if user has already made a choice
    const consent = localStorage.getItem('osbord-cookie-consent');

    if (!consent) {
      // Show banner with a slight delay
      setTimeout(() => {
        banner.classList.remove('hidden');
        // Trigger slide-in animation
        requestAnimationFrame(() => {
          banner.classList.remove('translate-y-full');
        });
      }, 1000);
    }

    const hideBanner = () => {
      banner.classList.add('translate-y-full');
      setTimeout(() => {
        banner.classList.add('hidden');
      }, 500);
    };

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('osbord-cookie-consent', 'accepted');
      hideBanner();
    });

    rejectBtn.addEventListener('click', () => {
      localStorage.setItem('osbord-cookie-consent', 'rejected');
      hideBanner();
    });
  });
</script>
