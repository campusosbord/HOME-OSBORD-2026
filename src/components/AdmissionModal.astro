---
interface Props {
  isUS?: boolean;
  programName?: string;
}

const { isUS, programName } = Astro.props;
const city = Astro.locals.city || "USA (Ciudad no detectada)";
const origin = Astro.url.href;

const programs = [
  "Máster en Interiorismo, Diseño y Decoración de Interiores 3D",
  "Máster en Organización de Eventos & Wedding Planner + IA",
  "Curso Profesional Superior: Auxiliar de Enfermería Clínica"
];
---

<div id="admission-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-brand-navy/80 backdrop-blur-sm transition-opacity" id="modal-backdrop"></div>

  <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
    <div class="relative transform overflow-hidden rounded-brand-xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-xl animate-scale-in">
      
      <!-- Close Button -->
      <button id="close-modal" class="absolute top-6 right-6 text-gray-400 hover:text-brand-navy transition-colors z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      {isUS ? (
        /* US VERSION: Institutional Form */
        <div class="p-6 sm:p-10">
          <div class="text-center mb-8 space-y-2 w-full flex flex-col items-center">
            <span class="block text-[12px] text-brand-gold font-bold uppercase tracking-[0.2em] w-full">Admisiones Institucionales</span>
            <h2 class="text-3xl font-extrabold text-brand-navy w-full" id="modal-title">Solicitud de Información</h2>
            <p class="text-gray-500 text-[14px] leading-relaxed w-full">Complete el siguiente formulario para recibir la información y los requisitos de admisión.</p>
          </div>

          <form class="space-y-4" id="admission-form">
            <input type="hidden" name="ciudad" value={city} />
            <input type="hidden" name="origen" value={origin} />
            
            {programName ? (
              <input type="hidden" name="formacion" value={programName} />
            ) : null}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Nombre Completo</label>
                <input type="text" name="nombre" placeholder="Ej. Juan Pérez" class="w-full px-5 py-2.5 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-sm text-brand-navy placeholder:text-gray-300" required />
              </div>
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Correo Electrónico</label>
                <input type="email" name="correo" placeholder="email@ejemplo.com" class="w-full px-5 py-2.5 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-sm text-brand-navy placeholder:text-gray-300" required />
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Teléfono</label>
                <input type="tel" name="telefono" placeholder="+1..." class="w-full px-5 py-2.5 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-sm text-brand-navy placeholder:text-gray-300" required />
              </div>
              
              {!programName && (
                <div class="space-y-1.5">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Programa de Interés</label>
                  <select name="formacion" class="w-full px-5 py-2.5 rounded-brand border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-2 focus:ring-brand-gold/20 focus:border-brand-gold/30 outline-none transition-all text-sm text-brand-navy appearance-none" required>
                    <option value="" disabled selected>Selecciona un programa</option>
                    {programs.map(p => <option value={p}>{p}</option>)}
                  </select>
                </div>
              )}

              {programName && (
                <div class="space-y-1.5">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400 ml-1">Programa Seleccionado</label>
                  <input type="text" value={programName} class="w-full px-5 py-2.5 rounded-brand border border-gray-200 bg-gray-100 text-sm text-gray-400 outline-none cursor-not-allowed" disabled />
                </div>
              )}
            </div>

            <div class="space-y-2 py-1">
              <p class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">¿Este Número Tiene WhatsApp?</p>
              <div class="flex items-center gap-4">
                <label class="flex items-center gap-2 cursor-pointer group">
                  <input type="radio" name="whatsapp" value="si" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">Sí</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer group">
                  <input type="radio" name="whatsapp" value="no" class="w-3.5 h-3.5 border-gray-300 text-brand-gold focus:ring-brand-gold" required />
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider group-hover:text-brand-gold transition-colors text-brand-navy">No</span>
                </label>
              </div>
            </div>

            <div class="pt-4 flex flex-col items-center gap-3">
              <button type="submit" class="cta-button px-10 py-3 shadow-lg shadow-brand-gold/10 flex items-center gap-2 text-xs">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                ENVIAR SOLICITUD DE ADMISIÓN
              </button>
              
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Respuesta en menos de 24 horas</p>
              </div>
            </div>
            <p class="text-[9px] text-center text-gray-400 mt-4 uppercase tracking-[0.2em] font-medium">Procesamiento de solicitud prioritario</p>
          </form>
        </div>
      ) : (
        /* LATAM VERSION: Elegant WhatsApp Box */
        <div class="p-0 overflow-hidden">
          <div class="bg-brand-navy p-8 text-center space-y-4">
             <div class="w-14 h-14 bg-brand-gold/10 rounded-full flex items-center justify-center mx-auto mb-1">
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                </svg>
             </div>
             <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-gold">Atención Personalizada</span>
             <h3 class="text-2xl font-extrabold text-white tracking-tight">Consultoría Académica</h3>
             <p class="text-gray-400 text-xs max-w-sm mx-auto">Conecta directamente con un asesor de admisiones para resolver tus dudas.</p>
          </div>
          
          <div class="p-8 bg-white">
            <div class="space-y-6">
              <div class="flex items-center gap-4 p-3 rounded-brand-lg bg-brand-neutral border border-gray-100">
                <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 border-2 border-white shadow-sm">
                  <img src="https://ui-avatars.com/api/?name=Osbord+Admissions&background=C5A059&color=fff" alt="Advisor" class="w-full h-full object-cover" />
                </div>
                <div>
                  <p class="text-xs font-bold text-brand-navy">Departamento de Admisiones</p>
                  <p class="text-[10px] text-brand-gold font-medium uppercase tracking-wider">En línea ahora</p>
                </div>
              </div>

              <div class="space-y-4 flex justify-center">
                <a href="https://wa.me/13072923715?text=Hola%2C%20vengo%20de%20la%20p%C3%A1gina%20del%20Instituto%20Osbord%20y%20estoy%20interesado%20en%20informaci%C3%B3n%20sobre%20un%20m%C3%A1ster%20o%20curso." target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#20ba5a] text-white font-extrabold py-3 px-10 rounded-brand shadow-xl shadow-green-500/20 transition-all duration-300 transform hover:-translate-y-1 text-xs uppercase tracking-widest">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
                  </svg>
                  WHATSAPP DIRECTO
                </a>
              </div>
              <div class="flex items-center justify-center gap-2">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                </span>
                <p class="text-[9px] text-gray-400 uppercase tracking-widest font-bold">Respuesta inmediata</p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-scale-in {
    animation: scale-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  const modal = document.getElementById('admission-modal');
  const closeBtn = document.getElementById('close-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const triggers = document.querySelectorAll('.trigger-admission-modal');

  function openModal(e: Event) {
    e.preventDefault();
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // Close mobile menu if open
    const sidebar = document.getElementById('mobile-sidebar');
    const backdrop = document.getElementById('mobile-backdrop');
    if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
      sidebar.classList.add('-translate-x-full');
      backdrop?.classList.add('opacity-0');
      backdrop?.classList.remove('opacity-100');
    }
  }

  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', openModal);
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // Close on Escape
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Form Submission Logic
  const admissionForm = document.getElementById('admission-form') as HTMLFormElement;
  
  // Client-side City Fallback (Plan B)
  async function resolveCity() {
    const cityInput = admissionForm.querySelector('input[name="ciudad"]') as HTMLInputElement;
    // Si la ciudad no se detectó, o solo se detectó el código de país (ej. "US")
    if (cityInput && (cityInput.value.includes('no detectada') || cityInput.value.length <= 3 || !cityInput.value)) {
      try {
        const res = await fetch('https://ipapi.co/json/');
        const geo = await res.json();
        if (geo.city) {
          cityInput.value = `${geo.city}, ${geo.region} (${geo.country_name})`;
        }
      } catch (e) {
        console.warn('Geo fallback failed');
      }
    }
  }

  // Run fallback on load
  if (admissionForm) resolveCity();

  admissionForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = admissionForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';

    // 1. ID único para deduplicación Meta (Pixel + Conversiones API)
    const eventId = 'lead_' + Date.now() + '_' + Math.random().toString(36).slice(2, 9);
    if ((window as any).fbq) (window as any).fbq('track', 'Lead', {}, { eventID: eventId });
    if ((window as any).gtag) (window as any).gtag('event', 'generate_lead');
    
    const formData = new FormData(admissionForm);
    const data: Record<string, string> = Object.fromEntries(formData.entries()) as Record<string, string>;

    // 2. Inyectar variables de seguimiento
    data.event_id = eventId;
    data.user_agent = navigator.userAgent;
    data.page_url = window.location.href;

    // 3. URLSearchParams para evitar bloqueo CORS
    const params = new URLSearchParams();
    for (const [key, value] of Object.entries(data)) {
      params.append(key, value);
    }
    
    try {
      const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzyWUx6b8Ys6Z6krDXOERDH7Z59iYf7--6hb6H9UHvyoSNM4mEs_ESnx1_LEwcGUuE/exec';
      
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        body: params
      });
      
      window.osbordToast?.();
      admissionForm.reset();
      closeModal();
    } catch (error) {
      console.error('Error:', error);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
