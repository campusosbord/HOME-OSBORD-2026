---
interface Props {
  limitTo?: string[];
}

const { limitTo } = Astro.props;

const allTeachers = [
  {
    name: "Prof. Alejandro Vivas",
    role: "Director de la Escuela de Diseño",
    bio: "Arquitecto y Diseñador con más de 15 años de experiencia en proyectos residenciales de lujo en Europa y Estados Unidos.",
    image: "/images/alejandro-vivas.png"
  },
  {
    name: "Dra. Carmen Luzardo",
    role: "Coordinadora de Ciencias de la Salud",
    bio: "Especialista en gestión hospitalaria y cuidados clínicos avanzados, con trayectoria en instituciones sanitarias de primer nivel.",
    image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=400&h=400&auto=format&fit=crop"
  },
  {
    name: "Raul Ramirez",
    role: "Docente de Organización de Eventos y Wedding Planner",
    bio: "Consultor experto en la industria del lujo y organización de eventos institucionales, especializado en protocolos internacionales.",
    image: "/images/raul-ramirez.png"
  }
];

const teachers = limitTo 
  ? allTeachers.filter(t => limitTo.includes(t.name))
  : allTeachers;
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center space-y-4 mb-16">
      <span class="section-label">El Factor Humano</span>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-navy">Nuestros <span class="text-brand-gold">docentes</span></h2>
      <div class="gold-divider mx-auto"></div>
      <p class="text-gray-500 max-w-2xl mx-auto mt-4">
        Contamos con un cuerpo docente, compuesto por profesionales en activo que aportan visión real y experiencia práctica al aula virtual.
      </p>
    </div>

    <div class={`grid gap-8 ${teachers.length === 1 ? 'max-w-md mx-auto grid-cols-1' : 'md:grid-cols-2 lg:grid-cols-3'}`}>
      {teachers.map(teacher => (
        <div class="group bg-brand-neutral/40 p-8 rounded-brand-xl border border-gray-100 hover:bg-white hover:shadow-elevated hover:border-brand-gold/20 transition-all duration-500">
          <div class="relative mb-8 flex justify-center">
             <div class="absolute inset-0 bg-brand-gold/10 rounded-full scale-110 group-hover:scale-125 transition-transform duration-500 blur-xl"></div>
             <img src={teacher.image} alt={teacher.name} class="relative w-32 h-32 rounded-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 border-4 border-white shadow-lg" />
          </div>
          
          <div class="text-center space-y-3">
            <h4 class="text-xl font-extrabold text-brand-navy">{teacher.name}</h4>
            <p class="text-xs text-brand-gold font-bold uppercase tracking-[0.15em] leading-relaxed px-4">
              {teacher.role}
            </p>
            <div class="w-8 h-0.5 bg-gray-200 mx-auto group-hover:w-16 group-hover:bg-brand-gold transition-all duration-500"></div>
            <p class="text-sm text-gray-500 leading-relaxed font-light">
              {teacher.bio}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
