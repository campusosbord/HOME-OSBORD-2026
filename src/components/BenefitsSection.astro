---
interface Benefit {
  title: string;
  description: string;
  icon: string;
  tag?: string;
}

interface Props {
  formationName: string;
  benefits: Benefit[];
}

const { formationName, benefits } = Astro.props;
---

<section class="py-16 bg-brand-neutral relative overflow-hidden">
  <!-- Decorative Background Elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-gold/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-navy/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 space-y-4">
      <span class="section-label">Ventajas de capacitarte</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-brand-navy">
        Beneficios de tu <span class="text-brand-gold">Formación</span>
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-lg leading-relaxed">
        Conoce todos los beneficios de conseguir la certificación internacional en nuestro {formationName}.
      </p>
      <div class="gold-divider mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit) => (
        <div class="bg-white p-8 rounded-brand-xl shadow-soft border border-gray-100 hover:border-brand-gold/30 hover:shadow-elevated transition-all duration-500 group">
          <div class="w-14 h-14 bg-brand-neutral rounded-brand flex items-center justify-center text-brand-gold mb-6 group-hover:scale-110 group-hover:bg-brand-gold/10 transition-all duration-300">
            <Fragment set:html={benefit.icon} />
          </div>
          <div class="space-y-3">
            {benefit.tag && (
              <span class="text-[9px] font-extrabold uppercase tracking-[0.2em] text-brand-gold bg-brand-gold/5 px-2 py-1 rounded">
                {benefit.tag}
              </span>
            )}
            <h3 class="text-xl font-extrabold text-brand-navy group-hover:text-brand-gold transition-colors">
              {benefit.title}
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              {benefit.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Strategic CTA -->
    <div class="mt-16 text-center">
      <div class="flex justify-center">
        {Astro.url.pathname.includes('/us') ? (
          <button class="trigger-admission-modal cta-button px-10 py-5 text-sm tracking-[0.1em] shadow-xl hover:scale-105 transition-all">
            SOLICITAR ADMISIÓN
          </button>
        ) : (
          <a href="https://wa.me/1234567890" class="cta-button flex items-center justify-center gap-3 font-extrabold px-10 py-5 rounded-brand shadow-xl shadow-brand-gold/20 transition-all duration-300 hover:scale-105">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
            </svg>
            HABLAR CON UN ASESOR POR WHATSAPP
          </a>
        )}
      </div>
    </div>
  </div>
</section>
