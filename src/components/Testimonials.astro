---
const testimonials = [
  {
    name: "Dra. Elena Martínez",
    role: "Egresada Máster en Aux. de Enfermería",
    text: "La calidad académica del Instituto Osbord superó mis expectativas. La metodología online me permitió compaginar mis estudios con mi trabajo en el hospital sin sacrificar profundidad técnica.",
    image: "https://i.pravatar.cc/150?u=elena"
  },
  {
    name: "Carlos Rivera",
    role: "Egresado Máster en Interiorismo 3D",
    text: "Gracias a la formación recibida, pude fundar mi propio estudio de diseño. Las herramientas y la mentoría de Osbord fueron la pieza clave para mi salto profesional al mercado internacional.",
    image: "https://i.pravatar.cc/150?u=carlos"
  },
  {
    name: "Sofía Valenzuela",
    role: "Egresada Máster en Wedding Planner",
    text: "Osbord no solo te da un título, te da una red de contactos invaluable. El enfoque en el mercado del lujo es lo que realmente marca la diferencia en esta industria.",
    image: "https://i.pravatar.cc/150?u=sofia"
  }
];
---

<section class="py-24 bg-brand-neutral/30">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center space-y-4 mb-16">
      <span class="section-label">Casos de Éxito</span>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-navy">La voz de nuestros <span class="text-brand-gold">egresados</span></h2>
      <div class="gold-divider mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white p-8 rounded-brand-xl shadow-soft border border-gray-100 flex flex-col justify-between hover:shadow-elevated transition-shadow duration-300">
          <div class="space-y-4">
            <div class="flex text-brand-gold">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-gray-600 italic leading-relaxed">"{t.text}"</p>
          </div>
          <div class="flex items-center gap-4 mt-8 pt-6 border-t border-gray-50">
            <img src={t.image} alt={t.name} class="w-12 h-12 rounded-full object-cover grayscale hover:grayscale-0 transition-all duration-300" />
            <div>
              <h4 class="text-sm font-extrabold text-brand-navy">{t.name}</h4>
              <p class="text-xs text-brand-gold font-bold uppercase tracking-wider">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
