      buttonText="SOLICITAR ADMISIÓN"
      buttonLink="https://wa.me/13072923715?text=Hola%2C%20vengo%20de%20la%20p%C3%A1gina%20del%20Instituto%20Osbord%20y%20estoy%20interesado%20en%20informaci%C3%B3n%20sobre%20un%20m%C3%A1ster%20o%20curso."
    />

