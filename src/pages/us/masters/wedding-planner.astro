---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CourseAccordion from '../../../components/CourseAccordion.astro';
import Testimonials from '../../../components/Testimonials.astro';
import FAQ from '../../../components/FAQ.astro';
import CTASection from '../../../components/CTASection.astro';
import TeachersSection from '../../../components/TeachersSection.astro';
import AccreditationBadge from '../../../components/AccreditationBadge.astro';
import { Image } from 'astro:assets';
import eventsImg from '../../../assets/school_events.png';
import LeadForm from '../../../components/LeadForm.astro';
import WhatsAppBox from '../../../components/WhatsAppBox.astro';
import BenefitsSection from '../../../components/BenefitsSection.astro';
import DiplomaSection from '../../../components/DiplomaSection.astro';

const isUS = true;
const programName = "Wedding Planner";
const formationFullName = "Máster Ejecutivo en Organización de Eventos & Wedding Planner";

const benefits = [
  {
    title: "Eventos de Autor",
    description: "Aprende a diseñar bodas y eventos con un sello distintivo de exclusividad, dominando el protocolo y las últimas tendencias de lujo.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>',
    tag: "Exclusividad"
  },
  {
    title: "IA Aplicada",
    description: "Optimiza tu tiempo y creatividad utilizando Inteligencia Artificial para el diseño de conceptos, moodboards y gestión logística eficiente.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>',
    tag: "Tecnología"
  },
  {
    title: "Certificación USA",
    description: "Obtén un título con respaldo internacional de nuestra sede en USA, garantizando los estándares más altos de la industria global.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84a51.39 51.39 0 00-2.658.814m-15.482 0l12.93 3.317a.5.5 0 00.254 0l12.93-3.317m-12.93 3.317V16.5"/></svg>',
    tag: "Internacional"
  },
  {
    title: "Negocio Propio",
    description: "Te entregamos las herramientas empresariales necesarias para lanzar y gestionar tu propia agencia de eventos con alta rentabilidad.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>',
    tag: "Emprendimiento"
  },
  {
    title: "Prestigio Global",
    description: "Forma parte de una élite de organizadores certificados, capacitados para trabajar en cualquier parte del mundo con estándares premium.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 22.125l-.394-1.558a1.907 1.907 0 00-1.541-1.541l-1.558-.394 1.558-.394a1.907 1.907 0 001.541-1.541l.394-1.558.394 1.558a1.907 1.907 0 001.541 1.541l1.558.394-1.558.394a1.907 1.907 0 00-1.541 1.541z"/></svg>',
    tag: "Estatus"
  },
  {
    title: "Networking de Lujo",
    description: "Accede a una red exclusiva de proveedores, venues y profesionales del sector nupcial internacional para potenciar tus eventos.",
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>',
    tag: "Contactos"
  }
];

const syllabus = [
  { 
    title: "MÓDULO 1. ORGANIZACIÓN DE EVENTOS", 
    content: [
      "Comunicación Estratégica y Protocolo Empresarial",
      "Perfil Profesional del Organizador y Gestión de Relaciones Estratégicas",
      "Ingeniería Financiera: Presupuestos y Contratación",
      "Tipologías y Protocolo de Eventos",
      "Diseño Estratégico, Creatividad y Selección de Sedes",
      "Operaciones Logísticas y Gestión de Proveedores",
      "Marketing, Difusión Digital y Relaciones con la Prensa",
      "Herramientas de Control: Checklists y Sistemas de Acceso",
      "Producción Técnica, Montaje y Nuevas Tecnologías",
      "Gestión de Riesgos, Seguridad y Sostenibilidad",
      "Auditoría de Resultados y Cierre de Proyecto",
      "Examen de Evaluación: Módulo 1."
    ]
  },
  { 
    title: "MÓDULO 2. WEDDING PLANNER", 
    content: [
      "Perfil Profesional del Wedding Planner: Competencias y Alcance",
      "Estructura Macro de la Boda: Fases de la Planificación",
      "La Entrevista Inicial: Definición de Estilo, Magnitud y Presupuesto",
      "Formalidades y Protocolos: Bodas Civiles, Religiosas y Multiculturales",
      "Conceptualización del Evento: Estilos, Horarios y Tipologías de Venues",
      "Gestión de Invitados: Estrategia de Convocatoria y Papelería Digital",
      "Protocolo Ceremonial y Etiqueta Social",
      "Gestión de Espacios (Venue Selection): Logística y Emplazamientos",
      "Selección y Dirección de Proveedores (Vendor Management)",
      "Gastronomía de Bodas: Del Banquete a la Experiencia Culinaria",
      "Diseño Atmosférico: Decoración, Paisajismo e Iluminación",
      "Blindaje Legal: Contratos, Pólizas y Gestión de Riesgos",
      "Entretenimiento y Diseño de Experiencias: Música y Animación",
      "Asesoría de Imagen y Estilismo para los Contrayentes",
      "Logística de Transporte, Alojamiento y «Guest Experience»",
      "El Cronograma Maestro (Master Timeline) y Plan de Rodaje",
      "Herramientas Tecnológicas para la Gestión Operativa",
      "Protocolos de Crisis y Plan de Contingencia",
      "El Cronograma de la Novia y Cortejo: Del Pre-Boda al Altar",
      "Destination Weddings: Logística de Bodas de Destino",
      "Cierre Administrativo y Auditoría Post-Evento",
      "Sostenibilidad y Bodas Eco-Friendly (Green Weddings)",
      "Psicología del Wedding Planner: Manejo de Clientes y Crisis Emocionales",
      "Micro-Weddings y Elopements: La Tendencia de lo Íntimo",
      "Bodas de Lujo (Luxury Weddings) y Conciergerie",
      "Ingeniería Financiera del Wedding Planner: Presupuestos y Rentabilidad",
      "Inclusión y Diversidad en la Industria Nupcial",
      "El Maletín del Wedding Planner: Herramientas de Campo y Kit de Emergencia",
      "Examen de Evaluación: Módulo 2."
    ]
  },
  { 
    title: "MÓDULO 3. POST-WEDDINNG (DESPUÉS DE LA BODA)", 
    content: [
      "Ingeniería del Cierre: Auditoría Técnica y Estrategias de Fidelización",
      "Luna de Miel",
      "Examen de Evaluación: Módulo 3."
    ]
  },
  { 
    title: "MÓDULO 4. EMPRESA DE EVENTOS Y BODAS (ORGANIZACIÓN LEGAL)", 
    content: [
      "Constitución y Estructura Legal de la Empresa de Eventos",
      "Branding, Identidad e Imagen Corporativa (El ADN del Negocio)",
      "Marketing Estratégico para Empresas de Eventos y Bodas",
      "Examen de Evaluación: Módulo 4."
    ]
  },
  { 
    title: "MÓDULO 5. CELEBRACIONES MÁGICAS: BABY SHOWER, GENDER REVEAL Y EVENTOS INFANTILES DE ÉXITO", 
    content: [
      "Gender Reveal: El Arte de la Revelación",
      "Baby Shower: Bienvenida y Ternura",
      "Bautizos y Primeras Comuniones",
      "El Primer Año y el Evento \"Smash the Cake\"",
      "Fiestas Infantiles Temáticas y Logística de Ocio",
      "Logística de Cumpleaños Infantiles: Del Aula a los Externos",
      "Examen de Evaluación: Módulo 5."
    ]
  },
  { 
    title: "MÓDULO 6. EL SUEÑO HECHO REALIDAD: ORGANIZACIÓN DE XV AÑOS Y SWEET 16 DE ALTO IMPACTO", 
    content: [
      "Psicología y Diseño del Evento Soñado",
      "Protocolo Tradicional y Ceremonial de Gala",
      "La Corte de Honor y Producción Coreográfica",
      "Estilismo, Moda y Look de la Protagonista",
      "Producción Técnica y Ambientación Escenográfica",
      "Entretenimiento Premium y Experiencia Digital",
      "Examen de Evaluación: Módulo 6."
    ]
  },
  { 
    title: "MÓDULO 7. CELEBRACIONES DE VIDA: CUMPLEAÑOS DE ADULTOS Y ANIVERSARIOS DE IMPACTO", 
    content: [
      "Estrategia y Psicología del Cliente Adulto",
      "Conceptualización Creativa y Diseño de Atmósferas",
      "Alta Gastronomía y Mixología de Autor",
      "Aniversarios y Renovación de Votos",
      "Entretenimiento y Curaduría Musical",
      "Gestión Operativa y Cierre de Proyecto",
      "Examen de Evaluación: Módulo 7."
    ]
  },
  { 
    title: "MÓDULO 8. CORPORATE ELITE: INGENIERÍA DE EVENTOS EMPRESARIALES Y LANZAMIENTOS DE MARCA", 
    content: [
      "Ingeniería de Eventos MICE y Congresos",
      "Protocolo de Estado y Relaciones Públicas Empresariales",
      "Lanzamiento de Producto y Marketing de Eventos",
      "Team Building y Clima Organizacional",
      "Catering Corporativo y Logística de Alimentos",
      "Estrategia de Patrocinio y Sponsorship de Éxito",
      "Examen de Evaluación: Módulo 8."
    ]
  },
  { 
    title: "MÓDULO 9. EL FUTURO DE LOS EVENTOS: INTELIGENCIA ARTIFICIAL, SOSTENIBILIDAD Y DISEÑO DE EXPERIENCIAS", 
    content: [
      "IA Generativa: Productividad y Creatividad 4.0",
      "IA en la Logística y Atención al Invitado",
      "Eventos Sostenibles y Eco-Producción (Zero Waste)",
      "Neuromarketing y Diseño Sensorial",
      "Storytelling y Narrativa Transviva",
      "Destination Events y Turismo de Lujo",
      "Examen de Evaluación: Módulo 9."
    ]
  },
  { 
    title: "MÓDULO 10. GESTIÓN DE AGENCIA 360º: NEGOCIACIÓN, BUSINESS DESIGN Y ESTRATEGIA DE VENTAS", 
    content: [
      "Software de Gestión y Productividad",
      "Business Design: Tarifas, Costes y Rentabilidad",
      "Marco Legal, Contratos y Seguros Profesionales",
      "Estrategia de Ventas y Negociación de Alto Nivel",
      "Branding Personal y Marketing Digital para Agencias",
      "Liderazgo, Equipos y Crecimiento de Agencia",
      "Examen de Evaluación: Módulo 10."
    ]
  },
  { 
    title: "MÓDULO 11. DiSEÑO Y PHOTOSHOP (PLUS)", 
    content: [
      "Herramientas de Photoshop",
      "Retoque",
      "Montaje de Propuestas Visuales",
      "Planos",
      "Examen de Evaluación: Módulo 11."
    ]
  },
  { 
    title: "EVALUACIÓN FINAL", 
    content: [
      "Evaluación Final"
    ]
  }
];


const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Máster Ejecutivo en Organización de Eventos & Wedding Planner",
  "description": "Formación profesional en organización de bodas y eventos de lujo. Protocolo, diseño, logística y marketing digital con certificación internacional.",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Instituto Online Osbord",
    "url": "https://osbord.edu"
  },
  "educationalLevel": "Máster",
  "numberOfCredits": 60,
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "Online",
    "courseWorkload": "PT600H"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://osbord.edu" },
    { "@type": "ListItem", "position": 2, "name": "Escuela de Gestión de Eventos", "item": "https://osbord.edu/escuela/eventos" },
    { "@type": "ListItem", "position": 3, "name": "Máster Ejecutivo en Organización de Eventos & Wedding Planner", "item": "https://osbord.edu/masters/wedding-planner" }
  ]
};
---

<Layout
  title="Máster Ejecutivo en Organización de Eventos & Wedding Planner"
  description="Conviértete en un experto en organización de bodas y eventos de lujo con Inteligencia Artificial. Certificación internacional con diploma apostillado."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header />
  <main>
    <!-- Course Hero -->
    <section class="bg-brand-navy py-24 lg:py-32 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-40">
        <Image src={eventsImg} alt="Wedding Planning Profesional" class="w-full h-full object-cover" width={1920} height={1080} loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/60 to-transparent"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <nav class="mb-12" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs text-gray-400">
            <li><a href="/us/" class="hover:text-brand-gold transition-colors">Inicio</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/us/escuela/eventos" class="hover:text-brand-gold transition-colors">Gestión de Eventos</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-gold font-semibold text-[10px] tracking-widest">Wedding Planner & IA</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8 animate-fade-in-up">
            <span class="section-label">Escuela de Gestión de Eventos</span>
            <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight uppercase">
              MÁSTER EJECUTIVO EN <span class="text-brand-gold">WEDDING PLANNER</span>
            </h1>
            <div class="flex items-center gap-4">
              <div class="w-12 h-1 bg-brand-gold"></div>
              <p class="text-xl text-white font-bold tracking-widest uppercase">
                & Organización de Eventos
              </p>
            </div>
            <p class="text-lg text-gray-200 max-w-lg leading-relaxed">
              Domina el arte de crear bodas y eventos inolvidables con el apoyo de herramientas de IA. Protocolo, diseño y gestión empresarial para el mercado del lujo.
            </p>

            <!-- Stats Row -->
            <div class="flex flex-wrap items-center gap-8 pt-4">
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">12</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Módulos</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">3 Meses</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Duración</p>
              </div>
              <div class="w-px h-10 bg-white/20"></div>
              <div class="flex flex-col">
                <p class="text-brand-gold font-extrabold text-3xl">Online</p>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">Modalidad</p>
              </div>
            </div>
          </div>

          <!-- Form Side (US) or WhatsApp (Latam) -->
          <div class="relative animate-fade-in-up delay-300">
            <div class="absolute -top-10 -right-6 z-20">
              <AccreditationBadge className="scale-75 md:scale-90" />
            </div>
            {isUS ? (
              <LeadForm programName={formationFullName} />
            ) : (
              <WhatsAppBox programName={programName} />
            )}
          </div>
        </div>
      </div>
    </section>


    <!-- Syllabus Section -->
    <section class="section-padding bg-white">
      <div class="grid lg:grid-cols-3 gap-16">
        <div class="lg:col-span-1 space-y-6">
          <p class="section-label">Plan de Estudios</p>
          <h2 class="text-3xl font-extrabold tracking-tight">Programa Académico</h2>
          <div class="gold-divider"></div>
          <p class="text-gray-500 leading-relaxed">
            Un programa diseñado para convertirte en un profesional integral de la organización de eventos de lujo a nivel internacional.
          </p>

          <div class="p-6 bg-brand-neutral rounded-brand-lg border border-gray-100 space-y-4">
            <h4 class="font-extrabold text-sm uppercase tracking-wider">¿Qué incluye?</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Kit de herramientas de planificación.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Plantillas de presupuesto profesionales.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Diploma apostillado por la Haya.
              </li>
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-brand-gold/10 flex items-center justify-center flex-shrink-0">
                  <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
                </span>
                Red de contactos de proveedores premium.
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-2">
          <CourseAccordion syllabus={syllabus} />
        </div>
      </div>
    </section>

    <BenefitsSection formationName={programName} benefits={benefits} />

    <TeachersSection limitTo={["Raul Ramirez"]} />
    <DiplomaSection />
    <Testimonials />
    <FAQ />

    <CTASection
      variant="dark"
      headline="Crea eventos que dejen huella"
      subtext="Únete a la próxima cohorte del Máster en Wedding Planner y posiciónate como referente en la industria nupcial internacional."
      buttonText="SOLICITAR ADMISIÓN"
    />
  </main>
  <Footer />
</Layout>
