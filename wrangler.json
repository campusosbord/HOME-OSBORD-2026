{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "home-osbord-nuevo-opus",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "placeholder"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
