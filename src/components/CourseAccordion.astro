---
interface Props {
  syllabus: {
    title: string;
    content: string | string[];
  }[];
}

const { syllabus } = Astro.props;

const accordionPathname = Astro.url.pathname;
const accordionIsUS = accordionPathname.startsWith('/us');
const accordionProgramMap: Record<string, string> = {
  'enfermeria': 'Curso Profesional Superior: Auxiliar de Enfermería Clínica',
  'interiorismo': 'Máster en Interiorismo, Diseño y Decoración de Interiores 3D',
  'wedding-planner': 'Máster Ejecutivo en Organización de Eventos & Wedding Planner',
};
const accordionMasterMatch = accordionPathname.match(/\/masters\/([^/]+)/);
const accordionCurrentProgram = accordionMasterMatch ? (accordionProgramMap[accordionMasterMatch[1]] ?? undefined) : undefined;
const accordionWhatsappUrl = accordionCurrentProgram
  ? `https://wa.me/13072923715?text=${encodeURIComponent('Hola, vengo de la página del Instituto Osbord y estoy interesado en información sobre el ' + accordionCurrentProgram + '.')}`
  : undefined;
---

<div class="space-y-3" role="list">
  {syllabus.map((item, index) => (
    <details name="syllabus" class="group bg-white rounded-brand border border-gray-100 open:shadow-soft transition-all duration-300" role="listitem">
      <summary class="flex justify-between items-center p-4 md:p-5 cursor-pointer list-none focus:outline-none select-none">
        <div class="flex items-center gap-4">
          <span class="flex-shrink-0 w-10 h-10 rounded-brand bg-brand-gold/10 flex items-center justify-center text-brand-gold font-extrabold text-xs transition-all duration-300">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <span class="font-extrabold text-xs md:text-sm text-brand-navy group-open:text-brand-gold transition-colors duration-300 uppercase tracking-widest">
            {item.title}
          </span>
        </div>
        <span class="flex-shrink-0 ml-4 text-brand-gold transition-transform duration-500 group-open:rotate-180">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </span>
      </summary>
      
      <div class="px-5 md:px-14 pb-6 md:pb-8">
        <div class="border-t border-gray-100 pt-6">
          {Array.isArray(item.content) ? (() => {
            const topics = item.content.filter(u => !u.toLowerCase().includes('examen'));
            const exams = item.content.filter(u => u.toLowerCase().includes('examen'));
            const half = Math.ceil(topics.length / 2);
            const leftCol = topics.slice(0, half);
            const rightCol = [...topics.slice(half), ...exams];

            return (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-3">
                {/* Columna Izquierda */}
                <div class="space-y-3">
                  {leftCol.map((unit) => (
                    <div class="flex items-start gap-3 group/unit">
                      <div class="mt-1 flex-shrink-0 w-4 h-4 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      </div>
                      <span class="text-xs md:text-sm font-semibold text-gray-500 group-hover/unit:text-brand-navy transition-colors duration-300">
                        {unit}
                      </span>
                    </div>
                  ))}
                </div>
                {/* Columna Derecha */}
                <div class="space-y-3">
                  {rightCol.map((unit) => (
                    <div class="flex items-start gap-3 group/unit">
                      <div class="mt-1 flex-shrink-0 w-4 h-4 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      </div>
                      <span class={`text-xs md:text-sm font-semibold transition-colors duration-300 ${unit.toLowerCase().includes('examen') ? 'text-brand-navy font-extrabold' : 'text-gray-500 group-hover/unit:text-brand-navy'}`}>
                        {unit}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })() : (
            <p class="text-gray-500 leading-relaxed text-xs md:text-sm font-medium">
              {item.content}
            </p>
          )}
        </div>
      </div>
    </details>
  ))}

  <!-- Strategic CTA for conversion after reading syllabus -->
  <div class="pt-8 text-center animate-fade-in-up">
    <div class="flex justify-center">
      {accordionIsUS ? (
        <button class="trigger-admission-modal cta-button px-10 py-5 text-sm tracking-[0.1em] shadow-xl hover:scale-105 transition-all">
          SOLICITAR ADMISIÓN
        </button>
      ) : accordionWhatsappUrl ? (
        <a href={accordionWhatsappUrl} target="_blank" rel="noopener noreferrer" class="cta-button flex items-center justify-center gap-3 font-extrabold px-10 py-5 rounded-brand shadow-xl shadow-brand-gold/20 transition-all duration-300 hover:scale-105">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
          </svg>
          CONSULTAR SOBRE EL PROGRAMA
        </a>
      ) : (
        <button class="trigger-admission-modal cta-button flex items-center justify-center gap-3 font-extrabold px-10 py-5 rounded-brand shadow-xl shadow-brand-gold/20 transition-all duration-300 hover:scale-105">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 0 5.415 0 12.05c0 2.12.554 4.189 1.605 6.01L0 24l6.135-1.61a11.902 11.902 0 0 0 5.915 1.56h.005c6.637 0 12.05-5.415 12.05-12.05a11.815 11.815 0 0 0-3.542-8.513"/>
          </svg>
          SOLICITAR ADMISIÓN
        </button>
      )}
    </div>
  </div>
</div>
