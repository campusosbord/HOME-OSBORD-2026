---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SchoolSection from '../components/SchoolSection.astro';
import StatsSection from '../components/StatsSection.astro';
import ExclusivitySection from '../components/ExclusivitySection.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Osbord USA — Institutional Admission"
  description="Instituto Online Osbord USA. High-ticket master's programs with international certification and institutional focus."
>
  <Header isUS={true} />
  <main>
    <Hero isUS={true} />
    <TrustBar />
    <SchoolSection />
    <StatsSection />
    <ExclusivitySection />
    
    <!-- Seccion de Formulario para USA -->
    <section id="contacto-usa" class="py-24 bg-brand-neutral">
      <div class="max-w-4xl mx-auto px-6">
        <div class="bg-white p-12 rounded-brand-xl shadow-elevated border border-gray-100">
          <div class="text-center mb-10 space-y-4">
            <span class="section-label">Institutional Admission</span>
            <h2 class="text-3xl font-extrabold tracking-tight">Request Program Information</h2>
            <p class="text-gray-500">Complete the form below to receive our institutional brochure and admission requirements.</p>
          </div>
          <form class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Full Name</label>
              <input type="text" placeholder="Your Name" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Email Address</label>
              <input type="email" placeholder="Your Email" class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all" />
            </div>
            <div class="md:col-span-2 space-y-2">
              <label class="text-xs font-bold uppercase tracking-wider text-gray-400">Program of Interest</label>
              <select class="w-full px-5 py-4 rounded-brand border border-gray-200 focus:ring-2 focus:ring-brand-gold/30 outline-none transition-all bg-white">
                <option>Máster en Interiorismo, Diseño y Decoración de Interiores 3D</option>
                <option>Máster en Organización de Eventos & Wedding Planner + IA</option>
                <option>CURSO PROFESIONAL SUPERIOR: AUXILIAR DE ENFERMERÍA CLÍNICA</option>
              </select>
            </div>
            <div class="md:col-span-2 pt-4">
              <button type="button" class="cta-button w-full justify-center py-4">SUBMIT APPLICATION</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <Testimonials />
    <FAQ />
  </main>
  <Footer isUS={true} />
</Layout>
